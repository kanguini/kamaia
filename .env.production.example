# ═══════════════════════════════════════════════════════════
# Kamaia — Production Environment Variables
# ═══════════════════════════════════════════════════════════

# ── API (Railway) ─────────────────────────────────────────
# DATABASE_URL is auto-provisioned by Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:port/database

# JWT secrets — generate with: openssl rand -base64 32
JWT_SECRET=<GENERATE_STRONG_SECRET>
JWT_REFRESH_SECRET=<GENERATE_STRONG_SECRET>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Application
PORT=3001
APP_ENV=production
FRONTEND_URL=https://kamaia.vercel.app

# Notifications — Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Kamaia <alerts@kamaia.ao>

# Notifications — Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Notifications — VAPID Web Push
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@kamaia.ao

# ── Web (Vercel) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://kamaia-api.up.railway.app/api

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL=https://kamaia.vercel.app
NEXTAUTH_SECRET=<GENERATE_STRONG_SECRET>

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
