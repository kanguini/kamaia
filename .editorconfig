# EditorConfig — https://editorconfig.org
# Uniformiza indentação, line endings e charset entre editores.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown preserva trailing whitespace (2 espaços = line break)
[*.md]
trim_trailing_whitespace = false

# Makefiles exigem tabs
[Makefile]
indent_style = tab

# SQL — convenção mais espaçada para leitura
[*.sql]
indent_size = 4

# Prisma schema usa 2 spaces
[*.prisma]
indent_size = 2
