NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Social OAuth providers (Google, Microsoft) are disabled for now.
# See apps/web/src/app/api/auth/[...nextauth]/route.ts to re-enable.

# Web Push (notificações push) — DESACTIVADO por defeito.
# Manter `false` enquanto o backend não tiver infra Web Push: modelo Prisma
# PushSubscription, chaves VAPID, rotas GET /notifications/vapid-public-key e
# POST /notifications/push/subscribe, e envio via web-push. Ver
# apps/web/src/hooks/use-push-notifications.ts.
NEXT_PUBLIC_PUSH_ENABLED=false

# Sentry — projecto kamaia-web (Next.js)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
