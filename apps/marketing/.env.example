# Public URLs
NEXT_PUBLIC_APP_URL=https://app.kamaia.cc
NEXT_PUBLIC_SITE_URL=https://kamaia.cc

# Contact form — envia para a API (apps/api /public-contacts)
# A API é a source-of-truth: guarda em DB + dispara email via Resend.
# RESEND_API_KEY + CONTACT_NOTIFY_EMAIL vivem agora em apps/api/.env.
NEXT_PUBLIC_API_URL=https://api.kamaia.cc

# Cloudflare Turnstile (anti-bot) — https://dash.cloudflare.com/?to=/:account/turnstile
# Par com TURNSTILE_SECRET_KEY na API.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Sentry — projecto kamaia-marketing (Next.js)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Analytics — Plausible (optional; script only loads when set)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Screenshot capture (scripts/capture-screenshots.ts)
SCREENS_BASE_URL=https://kamaia.vercel.app
SCREENS_USER_EMAIL=
SCREENS_USER_PASSWORD=
