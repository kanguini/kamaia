DATABASE_URL=postgresql://kamaia:kamaia_dev_2024@localhost:5432/kamaia
JWT_SECRET=kamaia-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=kamaia-dev-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
APP_PORT=3001
APP_ENV=development
FRONTEND_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════
# Sprint 7 — Alertas Reais
# ═══════════════════════════════════════

# Resend (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Kamaia <alerts@kamaia.ao>

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@kamaia.ao

# Gemini AI (Google) — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ═══════════════════════════════════════
# Formulário de contacto público (marketing)
# ═══════════════════════════════════════
# Email que recebe os contactos do site (kamaia.cc/contacto)
CONTACT_NOTIFY_EMAIL=heldermaiato@outlook.com
# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# Par com NEXT_PUBLIC_TURNSTILE_SITE_KEY no marketing.
TURNSTILE_SECRET_KEY=

# ═══════════════════════════════════════
# Document storage
# ═══════════════════════════════════════
# `local` (default): escreve em ./uploads (volume Railway em produção).
# `r2`: Cloudflare R2 — requer credentials abaixo + npm install do SDK.
STORAGE_DRIVER=local

# Apenas necessárias quando STORAGE_DRIVER=r2.
# Cria bucket em https://dash.cloudflare.com/?to=/:account/r2
# Gera API token "Object Read & Write" no bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kamaia-documents

# ═══════════════════════════════════════
# Observability — Sentry
# ═══════════════════════════════════════
# Cria projecto em https://sentry.io/ → Project → kamaia-api (Node.js)
# Vazio = SDK em modo noop. Recomendado em produção.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
