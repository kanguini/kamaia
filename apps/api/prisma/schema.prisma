// ═══════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  channel     NotificationChannel
  tipo        String              @db.VarChar(80)  // ex CONTRATO_VENCIMENTO_PROXIMO, IS_PENDENTE
  titulo      String              @db.VarChar(200)
  conteudo    String              @db.Text
  payload     Json?
  status      NotificationStatus  @default(PENDING)
  enviadoEm   DateTime?           @map("enviado_em") @db.Timestamptz
  lidoEm      DateTime?           @map("lido_em") @db.Timestamptz

  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, status])
  @@index([status, createdAt])
  @@map("notifications")
}

/// Evento de agenda criado pelo utilizador (reunião, prazo manual,
/// lembrete, audiência). Distinto das datas-chave/actos/obrigações,
/// que são derivadas de contratos — estes são entradas livres,
/// opcionalmente vinculadas a um contrato ou entidade para navegação.
model AgendaEvento {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid

  titulo      String           @db.VarChar(200)
  descricao   String?          @db.Text
  tipo        AgendaEventoTipo @default(GERAL)

  /// Instante de início (UTC). Para eventos de dia inteiro, diaInteiro
  /// = true e a componente horária deve ser ignorada na apresentação.
  inicio      DateTime         @db.Timestamptz
  /// Instante de fim (UTC), opcional. Quando ausente, o evento é
  /// pontual (sem duração explícita).
  fim         DateTime?        @db.Timestamptz
  diaInteiro  Boolean          @default(false) @map("dia_inteiro")

  local       String?          @db.VarChar(200)
  cor         String?          @db.VarChar(20)

  /// Vínculos opcionais para navegação contextual. entidadeId é um
  /// campo escalar (sem relação inversa) para evitar carga no modelo
  /// Entidade; contratoId tem relação para SetNull em soft delete.
  contratoId  String?          @map("contrato_id") @db.Uuid
  entidadeId  String?          @map("entidade_id") @db.Uuid

  createdBy   String           @map("created_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato    Contrato?        @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  @@index([tenantId, inicio])
  @@index([tenantId, deletedAt])
  @@map("agenda_eventos")
}

enum AgendaEventoTipo {
  GERAL
  REUNIAO
  PRAZO
  AUDIENCIA
  LEMBRETE
  ASSINATURA
}

// ─── Tarefas (gestor de trabalho humano) ──────────────────────────
//
// A peça que faltava: trabalho criado e atribuído a MEMBROS da equipa,
// com estado e prazo. Distinta dos sinais derivados (obrigações,
// compliance, datas-chave) — cruza-se com eles via `contratoId` e na
// vista unificada "O meu trabalho". Espelha o AgendaEvento nos vínculos
// opcionais (contrato/entidade) e aparece na Agenda quando tem prazo.

enum TarefaEstado {
  A_FAZER
  EM_CURSO
  CONCLUIDA
  CANCELADA
}

enum TarefaPrioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Tarefa {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid

  titulo         String           @db.VarChar(200)
  descricao      String?          @db.Text
  estado         TarefaEstado     @default(A_FAZER)
  prioridade     TarefaPrioridade @default(MEDIA)

  /// Prazo (UTC), opcional. Quando presente, a tarefa entra na Agenda
  /// e na fila priorizada de "O meu trabalho".
  dataVencimento DateTime?        @map("data_vencimento") @db.Timestamptz

  /// Responsável: um User com Membership no tenant (validado no service).
  responsavelId  String?          @map("responsavel_id") @db.Uuid

  /// Vínculos opcionais para contexto (espelha AgendaEvento). contratoId
  /// tem relação para SetNull em soft delete; entidadeId é escalar.
  contratoId     String?          @map("contrato_id") @db.Uuid
  entidadeId     String?          @map("entidade_id") @db.Uuid

  concluidaEm    DateTime?        @map("concluida_em") @db.Timestamptz
  concluidaPor   String?          @map("concluida_por") @db.Uuid

  createdBy      String           @map("created_by") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato       Contrato?        @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  responsavel    User?            @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  @@index([tenantId, responsavelId, estado])
  @@index([tenantId, estado, dataVencimento])
  @@index([tenantId, contratoId])
  @@index([tenantId, deletedAt])
  @@map("tarefas")
}

model PushSubscription {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  endpoint    String   @unique @db.Text
  p256dh      String   @db.Text
  auth        String   @db.Text
  userAgent   String?  @map("user_agent") @db.Text

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ═══════════════════════════════════════════════════════════
// API KEYS + WEBHOOKS (integração externa)
// ═══════════════════════════════════════════════════════════

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  nome        String    @db.VarChar(100)
  prefixo     String    @db.VarChar(12)
  keyHash     String    @unique @map("key_hash") @db.VarChar(200)
  scopes      String[]
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  createdBy   String    @map("created_by") @db.Uuid

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model Webhook {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  nome        String           @db.VarChar(100)
  url         String           @db.VarChar(500)
  events      String[]
  secret      String           @db.VarChar(200)
  isActive    Boolean          @default(true) @map("is_active")

  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([tenantId])
  @@map("webhooks")
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

model WebhookDelivery {
  id              String                @id @default(uuid()) @db.Uuid
  webhookId       String                @map("webhook_id") @db.Uuid
  event           String                @db.VarChar(80)
  payload         Json
  status          WebhookDeliveryStatus @default(PENDING)
  responseStatus  Int?                  @map("response_status")
  responseBody    String?               @map("response_body") @db.Text
  tentativas      Int                   @default(0)
  proximaTentativa DateTime?            @map("proxima_tentativa") @db.Timestamptz
  entregueEm      DateTime?             @map("entregue_em") @db.Timestamptz

  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz

  webhook         Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@map("webhook_deliveries")
}

// ═══════════════════════════════════════════════════════════
// COLABORAÇÃO EXTERNA — convidados scoped por contrato
// ═══════════════════════════════════════════════════════════

enum ColaboradorTipoAcesso {
  LEITURA       // só vê o contrato (read-only)
  COMENTARIO    // pode adicionar comentários
  ASSINATURA    // pode assinar (implica LEITURA)
}

enum ColaboradorEstado {
  PENDENTE      // convite enviado, não aceite
  ACTIVO        // aceitou e está a usar
  REVOGADO      // owner revogou acesso
  EXPIRADO      // TTL passou
}

/// Colaborador externo com acesso scoped a um único contrato.
/// O acesso é via magic link contendo o token; sem necessidade
/// de criar User na tenancy principal.
model ContratoColaborador {
  id                 String                @id @default(uuid()) @db.Uuid
  contratoId         String                @map("contrato_id") @db.Uuid
  email              String                @db.VarChar(200)
  nome               String?               @db.VarChar(200)
  tipoAcesso         ColaboradorTipoAcesso @map("tipo_acesso")
  estado             ColaboradorEstado     @default(PENDENTE)

  // Magic link
  tokenHash          String                @unique @map("token_hash") @db.VarChar(200)
  tokenPrefix        String                @map("token_prefix") @db.VarChar(8)  // para UI mostrar `xxx-xxxx`
  expiresAt          DateTime              @map("expires_at") @db.Timestamptz

  // Auditoria de acesso
  convidadoPor       String                @map("convidado_por") @db.Uuid
  convidadoEm        DateTime              @default(now()) @map("convidado_em") @db.Timestamptz
  aceitouEm          DateTime?             @map("aceitou_em") @db.Timestamptz
  revogadoEm         DateTime?             @map("revogado_em") @db.Timestamptz
  ultimaActividade   DateTime?             @map("ultima_actividade") @db.Timestamptz
  ipAddress          String?               @map("ip_address") @db.VarChar(45)
  userAgent          String?               @map("user_agent") @db.Text

  contrato           Contrato              @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  comentarios        ContratoComentario[]
  assinaturas        ContratoAssinatura[]

  @@index([contratoId, estado])
  @@index([email])
  @@index([expiresAt])
  @@map("contrato_colaboradores")
}

// ═══════════════════════════════════════════════════════════
// COMENTÁRIOS por cláusula (threads internas + externas)
// ═══════════════════════════════════════════════════════════

enum ComentarioAutorTipo {
  USER             // colaborador interno do tenant
  COLABORADOR      // convidado externo (ContratoColaborador)
}

/// Comentário por âncora dentro do markdown do contrato.
/// `clausulaRef` é um anchor estável (ex: "cl-5.2" ou linha range).
/// Suporta threads via `parentComentarioId`.
model ContratoComentario {
  id                String              @id @default(uuid()) @db.Uuid
  contratoId        String              @map("contrato_id") @db.Uuid
  versaoId          String?             @map("versao_id") @db.Uuid
  clausulaRef       String              @map("clausula_ref") @db.VarChar(200)
  parentComentarioId String?            @map("parent_comentario_id") @db.Uuid

  // Autor (uma das duas FKs preenchidas)
  autorTipo         ComentarioAutorTipo @map("autor_tipo")
  autorUserId       String?             @map("autor_user_id") @db.Uuid
  autorColaboradorId String?            @map("autor_colaborador_id") @db.Uuid
  autorNome         String              @map("autor_nome") @db.VarChar(200)  // denormalizado p/ histórico

  texto             String              @db.Text
  resolvido         Boolean             @default(false)
  resolvidoEm       DateTime?           @map("resolvido_em") @db.Timestamptz
  resolvidoPor      String?             @map("resolvido_por") @db.Uuid

  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz

  contrato          Contrato            @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  versao            ContratoVersao?     @relation(fields: [versaoId], references: [id])
  parent            ContratoComentario? @relation("Replies", fields: [parentComentarioId], references: [id])
  replies           ContratoComentario[] @relation("Replies")
  colaborador       ContratoColaborador? @relation(fields: [autorColaboradorId], references: [id])

  @@index([contratoId, resolvido])
  @@index([versaoId])
  @@index([clausulaRef])
  @@map("contrato_comentarios")
}

// ═══════════════════════════════════════════════════════════
// ASSINATURAS — colectadas dentro do produto
// ═══════════════════════════════════════════════════════════

enum AssinaturaMetodo {
  DESENHADA_BROWSER          // canvas pad
  MANUSCRITA_DIGITALIZADA    // upload de imagem
  CERTIFICADO_DIGITAL        // futuro: certificado qualificado
  PIN_SMS                    // futuro: confirmação via SMS
}

enum AssinaturaEstado {
  PENDENTE
  ASSINADA
  REJEITADA
  REVOGADA
}

/// Assinatura electrónica colectada — força probatória.
/// Para força executiva (Lei n.º 1/11) é preciso certificado qualificado.
/// O `hashContratoSnapshot` é o SHA256 do markdown da versão no momento
/// da assinatura; garante que a versão assinada não é adulterada.
model ContratoAssinatura {
  id                    String              @id @default(uuid()) @db.Uuid
  contratoId            String              @map("contrato_id") @db.Uuid
  versaoId              String              @map("versao_id") @db.Uuid
  parteId               String?             @map("parte_id") @db.Uuid     // ContratoParte
  colaboradorId         String?             @map("colaborador_id") @db.Uuid  // se assinado por convite externo
  signatarioNome        String              @map("signatario_nome") @db.VarChar(200)
  signatarioEmail       String?             @map("signatario_email") @db.VarChar(200)
  signatarioBI          String?             @map("signatario_bi") @db.VarChar(40)
  cargo                 String?             @db.VarChar(100)

  metodo                AssinaturaMetodo
  estado                AssinaturaEstado    @default(PENDENTE)

  // Conteúdo da assinatura
  imagemBase64          String?             @map("imagem_base64") @db.Text  // PNG da assinatura desenhada
  imagemStorageKey      String?             @map("imagem_storage_key") @db.VarChar(500)

  // Prova
  hashContratoSnapshot  String              @map("hash_contrato_snapshot") @db.VarChar(64)
  ipAddress             String?             @map("ip_address") @db.VarChar(45)
  userAgent             String?             @map("user_agent") @db.Text
  geoCidade             String?             @map("geo_cidade") @db.VarChar(100)
  geoPais               String?             @map("geo_pais") @db.VarChar(2)

  // Lifecycle
  solicitadaEm          DateTime            @default(now()) @map("solicitada_em") @db.Timestamptz
  assinadaEm            DateTime?           @map("assinada_em") @db.Timestamptz
  revogadaEm            DateTime?           @map("revogada_em") @db.Timestamptz
  observacoes           String?             @db.Text

  contrato              Contrato            @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  versao                ContratoVersao      @relation(fields: [versaoId], references: [id])
  colaborador           ContratoColaborador? @relation(fields: [colaboradorId], references: [id])

  @@index([contratoId, estado])
  @@index([versaoId])
  @@map("contrato_assinaturas")
}
