// ═══════════════════════════════════════════════════════════
// KAMAIA — Database Schema
// Platform: PostgreSQL 16 + pgvector
// ═══════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgvector(map: "vector", schema: "public")]
}

// ── Gabinete (Law Firm / Office) ──────────────────────────
// Equivalent to "Tenant" in HEXA Prime.
// A solo lawyer IS a gabinete of 1.

model Gabinete {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  nif       String?  @unique @db.VarChar(20)
  address   String?  @db.Text
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(200)
  logoUrl   String?  @map("logo_url") @db.VarChar(500)
  plan      String   @default("PRO_BUSINESS") @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users               User[]
  clientes            Cliente[]
  processos           Processo[]
  prazos              Prazo[]
  calendarEvents      CalendarEvent[]
  documents           Document[]
  auditLogs           AuditLog[]
  aiConversations     AIConversation[]
  subscription        Subscription?
  usageQuota          UsageQuota?
  timeEntries         TimeEntry[]
  expenses            Expense[]
  clienteInteractions ClienteInteraction[]
  taskColumns         TaskColumn[]
  tasks               Task[]
  notifications       Notification[]
  workflows           Workflow[]
  projects            Project[]
  projectTemplates    ProjectTemplateCustom[]
  invoices            Invoice[]
  holidays            Holiday[]
  tramitacoes         Tramitacao[]
  audiencias          Audiencia[]
  atendimentos        Atendimento[]

  @@map("gabinetes")
}

// ── User ──────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  gabineteId   String    @map("gabinete_id") @db.Uuid
  email        String    @db.VarChar(200)
  passwordHash String?   @map("password_hash") @db.VarChar(200)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  role         String    @db.VarChar(30)
  oaaNumber    String?   @map("oaa_number") @db.VarChar(30)
  specialty    String?   @db.VarChar(100)
  phone        String?   @db.VarChar(30)
  avatarUrl    String?   @map("avatar_url") @db.VarChar(500)
  provider     String    @default("credentials") @db.VarChar(20)
  providerId   String?   @map("provider_id") @db.VarChar(200)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete               Gabinete                @relation(fields: [gabineteId], references: [id])
  sessions               UserSession[]
  clientesManaged        Cliente[]               @relation("AdvogadoClientes")
  processos              Processo[]              @relation("AdvogadoProcessos")
  processoEvents         ProcessoEvent[]
  calendarEvents         CalendarEvent[]
  documents              Document[]              @relation("UploadedDocuments")
  auditLogs              AuditLog[]
  aiConversations        AIConversation[]
  timeEntries            TimeEntry[]
  expenses               Expense[]
  clienteInteractions    ClienteInteraction[]
  tasksAssigned          Task[]                  @relation("TaskAssignee")
  tasksCreated           Task[]                  @relation("TaskCreator")
  taskComments           TaskComment[]           @relation("TaskComments")
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  projectsManaged        Project[]               @relation("ProjectManager")
  projectsSponsored      Project[]               @relation("ProjectSponsor")
  projectMemberships     ProjectMember[]
  projectReportsCreated  ProjectStatusReport[]
  invoicesCreated        Invoice[]               @relation("InvoiceCreator")
  paymentsRecorded       InvoicePayment[]        @relation("PaymentRecorder")
  tramitacoes            Tramitacao[]
  audiencias             Audiencia[]
  atendimentosCreated    Atendimento[]           @relation("AtendimentoCreator")
  atendimentosAssigned   Atendimento[]           @relation("AtendimentoAssignee")

  @@unique([gabineteId, email], map: "uq_user_gabinete_email")
  @@unique([provider, providerId], map: "uq_user_provider")
  @@index([gabineteId], map: "idx_user_gabinete")
  @@index([gabineteId, role], map: "idx_user_gabinete_role")
  @@index([email], map: "idx_user_email")
  @@map("users")
}

// ── User Session ──────────────────────────────────────────

model UserSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(50)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_session_user")
  @@index([refreshToken], map: "idx_session_token")
  @@map("user_sessions")
}

// ── Cliente (Client CRM) ─────────────────────────────────

model Cliente {
  id         String    @id @default(uuid()) @db.Uuid
  gabineteId String    @map("gabinete_id") @db.Uuid
  advogadoId String?   @map("advogado_id") @db.Uuid
  type       String    @db.VarChar(20) // INDIVIDUAL | EMPRESA
  name       String    @db.VarChar(300)
  nif        String?   @db.VarChar(20)
  email      String?   @db.VarChar(200)
  phone      String?   @db.VarChar(30)
  address    String?   @db.Text
  notes      String?   @db.Text
  isActive   Boolean   @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete     Gabinete             @relation(fields: [gabineteId], references: [id])
  advogado     User?                @relation("AdvogadoClientes", fields: [advogadoId], references: [id], onDelete: SetNull)
  processos    Processo[]
  interactions ClienteInteraction[]
  tasks        Task[]
  Project      Project[]
  invoices     Invoice[]
  atendimentos Atendimento[]

  @@unique([gabineteId, nif], map: "uq_cliente_gabinete_nif")
  @@index([gabineteId], map: "idx_cliente_gabinete")
  @@index([gabineteId, advogadoId], map: "idx_cliente_gabinete_advogado")
  @@map("clientes")
}

// ── Atendimento (Lead / Prospecto) ────────────────────────
// Entry point of the pipeline: a prospecto/lead who made contact but
// has not yet been qualified into a Cliente + Processo. When converted,
// we keep references to the created Cliente/Processo for audit + reporting.

model Atendimento {
  id           String  @id @default(uuid()) @db.Uuid
  gabineteId   String  @map("gabinete_id") @db.Uuid
  createdById  String  @map("created_by_id") @db.Uuid
  assignedToId String? @map("assigned_to_id") @db.Uuid

  // Contact data (pre-cliente)
  name  String  @db.VarChar(300)
  type  String  @db.VarChar(20) // INDIVIDUAL | EMPRESA
  nif   String? @db.VarChar(20)
  email String? @db.VarChar(200)
  phone String? @db.VarChar(30)

  // Lead/case brief
  subject     String  @db.VarChar(500) // Short title / assunto
  description String? @db.Text
  source      String  @db.VarChar(20) // AtendimentoSource enum
  status      String  @default("NOVO") @db.VarChar(20) // AtendimentoStatus enum
  priority    String  @default("MEDIA") @db.VarChar(10) // ALTA | MEDIA | BAIXA
  notes       String? @db.Text

  // Conversion trail
  convertedClienteId  String?   @map("converted_cliente_id") @db.Uuid
  convertedProcessoId String?   @map("converted_processo_id") @db.Uuid
  convertedAt         DateTime? @map("converted_at") @db.Timestamptz
  lostReason          String?   @map("lost_reason") @db.VarChar(300)

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete          Gabinete  @relation(fields: [gabineteId], references: [id])
  createdBy         User      @relation("AtendimentoCreator", fields: [createdById], references: [id])
  assignedTo        User?     @relation("AtendimentoAssignee", fields: [assignedToId], references: [id])
  convertedCliente  Cliente?  @relation(fields: [convertedClienteId], references: [id])
  convertedProcesso Processo? @relation(fields: [convertedProcessoId], references: [id])

  @@index([gabineteId], map: "idx_atendimento_gabinete")
  @@index([gabineteId, status], map: "idx_atendimento_gabinete_status")
  @@index([gabineteId, assignedToId], map: "idx_atendimento_gabinete_assigned")
  @@map("atendimentos")
}

// ── Processo (Legal Case) ─────────────────────────────────

model Processo {
  id              String    @id @default(uuid()) @db.Uuid
  gabineteId      String    @map("gabinete_id") @db.Uuid
  clienteId       String    @map("cliente_id") @db.Uuid
  advogadoId      String    @map("advogado_id") @db.Uuid
  processoNumber  String    @map("processo_number") @db.VarChar(30)
  title           String    @db.VarChar(500)
  description     String?   @db.Text
  type            String    @db.VarChar(30) // ProcessoType enum
  status          String    @default("ACTIVO") @db.VarChar(20) // ProcessoStatus enum
  stage           String?   @db.VarChar(100) // Current stage within type
  court           String?   @db.VarChar(200)
  courtCaseNumber String?   @map("court_case_number") @db.VarChar(50)
  judge           String?   @db.VarChar(200)
  opposingParty   String?   @map("opposing_party") @db.VarChar(300)
  opposingLawyer  String?   @map("opposing_lawyer") @db.VarChar(200)
  priority        String    @default("MEDIA") @db.VarChar(10) // ALTA | MEDIA | BAIXA
  lifecycle       String    @default("ATENDIMENTO") @db.VarChar(30) // ProcessoLifecycle enum
  tags            String[]  @default([])
  feeType         String?   @map("fee_type") @db.VarChar(20) // FIXO | HORA | PERCENTAGEM | PRO_BONO
  feeAmount       Int?      @map("fee_amount") // Centavos AOA
  notes           String?   @db.Text
  strategy        String?   @db.Text // Notas estratégicas privadas: teses, riscos, cenários, plano de ataque/defesa
  openedAt        DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  closedAt        DateTime? @map("closed_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Dynamic workflow support (Sprint 1+)
  workflowId     String?                 @map("workflow_id") @db.Uuid
  workflow       Workflow?               @relation(fields: [workflowId], references: [id])
  stageInstances ProcessoStageInstance[]
  projectId      String?                 @map("project_id") @db.Uuid
  project        Project?                @relation(fields: [projectId], references: [id])

  gabinete     Gabinete        @relation(fields: [gabineteId], references: [id])
  cliente      Cliente         @relation(fields: [clienteId], references: [id])
  advogado     User            @relation("AdvogadoProcessos", fields: [advogadoId], references: [id])
  events       ProcessoEvent[]
  prazos       Prazo[]
  calendar     CalendarEvent[]
  documents    Document[]
  timeEntries  TimeEntry[]
  expenses     Expense[]
  tasks        Task[]
  invoices     Invoice[]
  tramitacoes  Tramitacao[]
  audiencias   Audiencia[]
  atendimentos Atendimento[]

  @@unique([gabineteId, processoNumber], map: "uq_processo_gabinete_number")
  @@index([gabineteId], map: "idx_processo_gabinete")
  @@index([gabineteId, status], map: "idx_processo_gabinete_status")
  @@index([gabineteId, lifecycle], map: "idx_processo_gabinete_lifecycle")
  @@index([gabineteId, advogadoId], map: "idx_processo_gabinete_advogado")
  @@index([gabineteId, clienteId], map: "idx_processo_gabinete_cliente")
  @@index([gabineteId, workflowId], map: "idx_processo_gabinete_workflow")
  @@index([gabineteId, projectId], map: "idx_processo_gabinete_project")
  @@map("processos")
}

// ── Processo Event (Timeline) ─────────────────────────────

model ProcessoEvent {
  id          String    @id @default(uuid()) @db.Uuid
  processoId  String    @map("processo_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  type        String    @db.VarChar(30) // ProcessoEventType enum
  description String    @db.Text
  metadata    Json?     @db.JsonB
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  processo Processo @relation(fields: [processoId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([processoId], map: "idx_evento_processo")
  @@map("processo_events")
}

// ── Tramitação (Acto Processual) ──────────────────────────
// Acto registado explicitamente pelo advogado — entrada rica com autor
// controlado (NOS / TRIBUNAL / CONTRAPARTE / MINISTERIO_PUBLICO / OUTRO),
// tipo de acto normalizado (citação, contestação, despacho, sentença,
// acórdão, etc.) e automações opcionais: pode gerar um Prazo vinculado
// e/ou disparar avanço de fase processual. Distinto de ProcessoEvent,
// que é o audit trail automático do sistema.

model Tramitacao {
  id         String @id @default(uuid()) @db.Uuid
  gabineteId String @map("gabinete_id") @db.Uuid
  processoId String @map("processo_id") @db.Uuid
  userId     String @map("user_id") @db.Uuid // quem registou

  autor       String   @db.VarChar(30) // TramitacaoAutor enum
  actoType    String   @map("acto_type") @db.VarChar(60) // slug controlado
  title       String   @db.VarChar(300)
  description String?  @db.Text
  actoDate    DateTime @map("acto_date") @db.Date // data do acto (pode ser anterior a createdAt)

  // Automações
  generatedPrazoId String? @map("generated_prazo_id") @db.Uuid
  advancedToStage  String? @map("advanced_to_stage") @db.VarChar(100) // WorkflowStage key ou label

  metadata  Json?     @db.JsonB
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete       Gabinete @relation(fields: [gabineteId], references: [id])
  processo       Processo @relation(fields: [processoId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  generatedPrazo Prazo?   @relation("TramitacaoGeneratedPrazo", fields: [generatedPrazoId], references: [id])

  @@index([gabineteId, processoId, actoDate], map: "idx_tramitacao_processo_date")
  @@index([processoId, autor], map: "idx_tramitacao_processo_autor")
  @@index([processoId, actoType], map: "idx_tramitacao_processo_type")
  @@map("tramitacoes")
}

// ── Audiência ─────────────────────────────────────────────
// Acto judicial presencial com ciclo de vida próprio: agendamento,
// realização ou adiamento. Distinto de Tramitacao (que regista o acto
// de "audiencia-agendada") — a Audiencia é a entidade que sobrevive a
// múltiplos adiamentos, mantém histórico e gere preparação (testemunhas,
// peças). Cada adiamento cria uma nova Audiencia ligada à anterior.

model Audiencia {
  id         String @id @default(uuid()) @db.Uuid
  gabineteId String @map("gabinete_id") @db.Uuid
  processoId String @map("processo_id") @db.Uuid
  userId     String @map("user_id") @db.Uuid // quem agendou

  type   String @db.VarChar(40) // AudienciaType enum
  status String @default("AGENDADA") @db.VarChar(20) // AudienciaStatus enum

  scheduledAt     DateTime  @map("scheduled_at") @db.Timestamptz
  heldAt          DateTime? @map("held_at") @db.Timestamptz
  durationMinutes Int?      @map("duration_minutes")

  location String? @db.VarChar(200) // sala / tribunal
  judge    String? @db.VarChar(200)
  notes    String? @db.Text // preparação / observações
  outcome  String? @db.Text // narrativa pós-audiência

  // Relação histórica: nova audiência após adiamento liga-se à anterior
  previousId String?     @map("previous_id") @db.Uuid
  previous   Audiencia?  @relation("AudienciaHistorico", fields: [previousId], references: [id])
  next       Audiencia[] @relation("AudienciaHistorico")

  metadata  Json?     @db.JsonB // testemunhas, peças, lista de presenças
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  processo Processo @relation(fields: [processoId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([gabineteId, processoId, scheduledAt], map: "idx_audiencia_processo_scheduled")
  @@index([gabineteId, status], map: "idx_audiencia_gabinete_status")
  @@index([gabineteId, scheduledAt], map: "idx_audiencia_gabinete_scheduled")
  @@map("audiencias")
}

// ── Prazo (Deadline) ──────────────────────────────────────

model Prazo {
  id               String    @id @default(uuid()) @db.Uuid
  gabineteId       String    @map("gabinete_id") @db.Uuid
  processoId       String    @map("processo_id") @db.Uuid
  title            String    @db.VarChar(300)
  description      String?   @db.Text
  type             String    @db.VarChar(30) // PrazoType enum
  dueDate          DateTime  @map("due_date") @db.Timestamptz
  alertHoursBefore Int       @default(48) @map("alert_hours_before")
  status           String    @default("PENDENTE") @db.VarChar(20) // PrazoStatus enum
  isUrgent         Boolean   @default(false) @map("is_urgent")
  completedAt      DateTime? @map("completed_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete          Gabinete     @relation(fields: [gabineteId], references: [id])
  processo          Processo     @relation(fields: [processoId], references: [id])
  tramitacoesOrigem Tramitacao[] @relation("TramitacaoGeneratedPrazo")

  @@index([gabineteId, dueDate], map: "idx_prazo_gabinete_due")
  @@index([gabineteId, status], map: "idx_prazo_gabinete_status")
  @@map("prazos")
}

// ── Calendar Event ────────────────────────────────────────

model CalendarEvent {
  id              String    @id @default(uuid()) @db.Uuid
  gabineteId      String    @map("gabinete_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  processoId      String?   @map("processo_id") @db.Uuid
  title           String    @db.VarChar(300)
  description     String?   @db.Text
  type            String    @db.VarChar(20) // CalendarEventType enum
  location        String?   @db.VarChar(300)
  startAt         DateTime  @map("start_at") @db.Timestamptz
  endAt           DateTime  @map("end_at") @db.Timestamptz
  allDay          Boolean   @default(false) @map("all_day")
  reminderMinutes Int?      @map("reminder_minutes")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete  @relation(fields: [gabineteId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  processo Processo? @relation(fields: [processoId], references: [id])

  @@index([gabineteId, startAt], map: "idx_calendar_gabinete_start")
  @@index([userId, startAt], map: "idx_calendar_user_start")
  @@map("calendar_events")
}

// ── Document ──────────────────────────────────────────────

model Document {
  id           String    @id @default(uuid()) @db.Uuid
  gabineteId   String    @map("gabinete_id") @db.Uuid
  processoId   String?   @map("processo_id") @db.Uuid
  projectId    String?   @map("project_id") @db.Uuid
  milestoneId  String?   @map("milestone_id") @db.Uuid
  taskId       String?   @map("task_id") @db.Uuid
  uploadedById String    @map("uploaded_by_id") @db.Uuid
  title        String    @db.VarChar(300)
  category     String    @db.VarChar(30) // DocumentCategory enum
  fileUrl      String    @map("file_url") @db.VarChar(500)
  fileSize     Int       @map("file_size") // Bytes
  mimeType     String    @map("mime_type") @db.VarChar(100)
  version      Int       @default(1)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete   Gabinete          @relation(fields: [gabineteId], references: [id])
  processo   Processo?         @relation(fields: [processoId], references: [id])
  project    Project?          @relation(fields: [projectId], references: [id])
  milestone  ProjectMilestone? @relation(fields: [milestoneId], references: [id])
  task       Task?             @relation(fields: [taskId], references: [id])
  uploadedBy User              @relation("UploadedDocuments", fields: [uploadedById], references: [id])

  @@index([gabineteId], map: "idx_document_gabinete")
  @@index([gabineteId, processoId], map: "idx_document_gabinete_processo")
  @@index([gabineteId, projectId], map: "idx_document_gabinete_project")
  @@index([gabineteId, milestoneId], map: "idx_document_gabinete_milestone")
  @@index([gabineteId, taskId], map: "idx_document_gabinete_task")
  @@map("documents")
}

// ── Audit Log (Append-Only) ──────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  gabineteId String   @map("gabinete_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(30) // AuditAction enum
  entity     String   @db.VarChar(30) // EntityType enum
  entityId   String?  @map("entity_id") @db.VarChar(50)
  oldValue   Json?    @map("old_value") @db.JsonB
  newValue   Json?    @map("new_value") @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
