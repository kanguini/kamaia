model ContratoObrigacao {
  id                  String                 @id @default(uuid()) @db.Uuid
  contratoId          String                 @map("contrato_id") @db.Uuid
  parteResponsavelId  String                 @map("parte_responsavel_id") @db.Uuid
  tipo                ObrigacaoTipo
  descricao           String                 @db.Text
