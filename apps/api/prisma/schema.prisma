  @@index([gabineteId, assigneeId], map: "idx_task_assignee")
  @@index([gabineteId, processoId], map: "idx_task_processo")
  @@index([gabineteId, projectId], map: "idx_task_project")
  @@index([gabineteId, milestoneId], map: "idx_task_milestone")
  @@map("tasks")
}

