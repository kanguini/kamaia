  registoEntidade          String?             @map("registo_entidade") @db.VarChar(100)
  registoReferencia        String?             @map("registo_referencia") @db.VarChar(200)

  // Comuns
  prazoLimite              DateTime?           @map("prazo_limite") @db.Date
