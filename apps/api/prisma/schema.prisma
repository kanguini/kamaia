// ═══════════════════════════════════════════════════════════
// KAMAIA — Database Schema
// Platform: PostgreSQL 16 + pgvector
// ═══════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgvector(map: "vector", schema: "public")]
}

// ── Gabinete (Law Firm / Office) ──────────────────────────
// Equivalent to "Tenant" in HEXA Prime.
// A solo lawyer IS a gabinete of 1.

model Gabinete {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  nif       String?  @unique @db.VarChar(20)
  address   String?  @db.Text
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(200)
  logoUrl   String?  @map("logo_url") @db.VarChar(500)
  plan      String   @default("PRO_BUSINESS") @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users               User[]
  clientes            Cliente[]
  processos           Processo[]
  prazos              Prazo[]
  calendarEvents      CalendarEvent[]
  documents           Document[]
  auditLogs           AuditLog[]
  aiConversations     AIConversation[]
  subscription        Subscription?
  usageQuota          UsageQuota?
  timeEntries         TimeEntry[]
  expenses            Expense[]
  clienteInteractions ClienteInteraction[]
  taskColumns         TaskColumn[]
  tasks               Task[]
  notifications       Notification[]
  workflows           Workflow[]
  projects            Project[]

  @@map("gabinetes")
}

// ── User ──────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  gabineteId   String    @map("gabinete_id") @db.Uuid
  email        String    @db.VarChar(200)
  passwordHash String?   @map("password_hash") @db.VarChar(200)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  role         String    @db.VarChar(30)
  oaaNumber    String?   @map("oaa_number") @db.VarChar(30)
  specialty    String?   @db.VarChar(100)
  phone        String?   @db.VarChar(30)
  avatarUrl    String?   @map("avatar_url") @db.VarChar(500)
  provider     String    @default("credentials") @db.VarChar(20)
  providerId   String?   @map("provider_id") @db.VarChar(200)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete               Gabinete                @relation(fields: [gabineteId], references: [id])
  sessions               UserSession[]
  clientesManaged        Cliente[]               @relation("AdvogadoClientes")
  processos              Processo[]              @relation("AdvogadoProcessos")
  processoEvents         ProcessoEvent[]
  calendarEvents         CalendarEvent[]
  documents              Document[]              @relation("UploadedDocuments")
  auditLogs              AuditLog[]
  aiConversations        AIConversation[]
  timeEntries            TimeEntry[]
  expenses               Expense[]
  clienteInteractions    ClienteInteraction[]
  tasksAssigned          Task[]                  @relation("TaskAssignee")
  tasksCreated           Task[]                  @relation("TaskCreator")
  taskComments           TaskComment[]           @relation("TaskComments")
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  projectsManaged        Project[]               @relation("ProjectManager")
  projectsSponsored      Project[]               @relation("ProjectSponsor")
  projectMemberships     ProjectMember[]

  @@unique([gabineteId, email], map: "uq_user_gabinete_email")
  @@unique([provider, providerId], map: "uq_user_provider")
  @@index([gabineteId], map: "idx_user_gabinete")
  @@index([gabineteId, role], map: "idx_user_gabinete_role")
  @@index([email], map: "idx_user_email")
  @@map("users")
}

// ── User Session ──────────────────────────────────────────

model UserSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(50)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_session_user")
  @@index([refreshToken], map: "idx_session_token")
  @@map("user_sessions")
}

// ── Cliente (Client CRM) ─────────────────────────────────

model Cliente {
  id         String    @id @default(uuid()) @db.Uuid
  gabineteId String    @map("gabinete_id") @db.Uuid
  advogadoId String?   @map("advogado_id") @db.Uuid
  type       String    @db.VarChar(20) // INDIVIDUAL | EMPRESA
  name       String    @db.VarChar(300)
  nif        String?   @db.VarChar(20)
  email      String?   @db.VarChar(200)
  phone      String?   @db.VarChar(30)
  address    String?   @db.Text
  notes      String?   @db.Text
  isActive   Boolean   @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete     Gabinete             @relation(fields: [gabineteId], references: [id])
  advogado     User?                @relation("AdvogadoClientes", fields: [advogadoId], references: [id])
  processos    Processo[]
  interactions ClienteInteraction[]
  tasks        Task[]
  Project      Project[]

  @@unique([gabineteId, nif], map: "uq_cliente_gabinete_nif")
  @@index([gabineteId], map: "idx_cliente_gabinete")
  @@index([gabineteId, advogadoId], map: "idx_cliente_gabinete_advogado")
  @@map("clientes")
}

// ── Processo (Legal Case) ─────────────────────────────────

model Processo {
  id              String    @id @default(uuid()) @db.Uuid
  gabineteId      String    @map("gabinete_id") @db.Uuid
  clienteId       String    @map("cliente_id") @db.Uuid
  advogadoId      String    @map("advogado_id") @db.Uuid
  processoNumber  String    @map("processo_number") @db.VarChar(30)
  title           String    @db.VarChar(500)
  description     String?   @db.Text
  type            String    @db.VarChar(30) // ProcessoType enum
  status          String    @default("ACTIVO") @db.VarChar(20) // ProcessoStatus enum
  stage           String?   @db.VarChar(100) // Current stage within type
  court           String?   @db.VarChar(200)
  courtCaseNumber String?   @map("court_case_number") @db.VarChar(50)
  judge           String?   @db.VarChar(200)
  opposingParty   String?   @map("opposing_party") @db.VarChar(300)
  opposingLawyer  String?   @map("opposing_lawyer") @db.VarChar(200)
  priority        String    @default("MEDIA") @db.VarChar(10) // ALTA | MEDIA | BAIXA
  lifecycle       String    @default("ATENDIMENTO") @db.VarChar(30) // ProcessoLifecycle enum
  tags            String[]  @default([])
  feeType         String?   @map("fee_type") @db.VarChar(20) // FIXO | HORA | PERCENTAGEM | PRO_BONO
  feeAmount       Int?      @map("fee_amount") // Centavos AKZ
  notes           String?   @db.Text
  openedAt        DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  closedAt        DateTime? @map("closed_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Dynamic workflow support (Sprint 1+)
  workflowId     String?                 @map("workflow_id") @db.Uuid
  workflow       Workflow?               @relation(fields: [workflowId], references: [id])
  stageInstances ProcessoStageInstance[]
  projectId      String?                 @map("project_id") @db.Uuid
  project        Project?                @relation(fields: [projectId], references: [id])

  gabinete    Gabinete        @relation(fields: [gabineteId], references: [id])
  cliente     Cliente         @relation(fields: [clienteId], references: [id])
  advogado    User            @relation("AdvogadoProcessos", fields: [advogadoId], references: [id])
  events      ProcessoEvent[]
  prazos      Prazo[]
  calendar    CalendarEvent[]
  documents   Document[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  tasks       Task[]

  @@unique([gabineteId, processoNumber], map: "uq_processo_gabinete_number")
  @@index([gabineteId], map: "idx_processo_gabinete")
  @@index([gabineteId, status], map: "idx_processo_gabinete_status")
  @@index([gabineteId, lifecycle], map: "idx_processo_gabinete_lifecycle")
  @@index([gabineteId, advogadoId], map: "idx_processo_gabinete_advogado")
  @@index([gabineteId, clienteId], map: "idx_processo_gabinete_cliente")
  @@index([gabineteId, workflowId], map: "idx_processo_gabinete_workflow")
  @@index([gabineteId, projectId], map: "idx_processo_gabinete_project")
  @@map("processos")
}

// ── Processo Event (Timeline) ─────────────────────────────

model ProcessoEvent {
  id          String    @id @default(uuid()) @db.Uuid
  processoId  String    @map("processo_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  type        String    @db.VarChar(30) // ProcessoEventType enum
  description String    @db.Text
  metadata    Json?     @db.JsonB
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  processo Processo @relation(fields: [processoId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([processoId], map: "idx_evento_processo")
  @@map("processo_events")
}

// ── Prazo (Deadline) ──────────────────────────────────────

model Prazo {
  id               String    @id @default(uuid()) @db.Uuid
  gabineteId       String    @map("gabinete_id") @db.Uuid
  processoId       String    @map("processo_id") @db.Uuid
  title            String    @db.VarChar(300)
  description      String?   @db.Text
  type             String    @db.VarChar(30) // PrazoType enum
  dueDate          DateTime  @map("due_date") @db.Timestamptz
  alertHoursBefore Int       @default(48) @map("alert_hours_before")
  status           String    @default("PENDENTE") @db.VarChar(20) // PrazoStatus enum
  isUrgent         Boolean   @default(false) @map("is_urgent")
  completedAt      DateTime? @map("completed_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  processo Processo @relation(fields: [processoId], references: [id])

  @@index([gabineteId, dueDate], map: "idx_prazo_gabinete_due")
  @@index([gabineteId, status], map: "idx_prazo_gabinete_status")
  @@map("prazos")
}

// ── Calendar Event ────────────────────────────────────────

model CalendarEvent {
  id              String    @id @default(uuid()) @db.Uuid
  gabineteId      String    @map("gabinete_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  processoId      String?   @map("processo_id") @db.Uuid
  title           String    @db.VarChar(300)
  description     String?   @db.Text
  type            String    @db.VarChar(20) // CalendarEventType enum
  location        String?   @db.VarChar(300)
  startAt         DateTime  @map("start_at") @db.Timestamptz
  endAt           DateTime  @map("end_at") @db.Timestamptz
  allDay          Boolean   @default(false) @map("all_day")
  reminderMinutes Int?      @map("reminder_minutes")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete  @relation(fields: [gabineteId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  processo Processo? @relation(fields: [processoId], references: [id])

  @@index([gabineteId, startAt], map: "idx_calendar_gabinete_start")
  @@index([userId, startAt], map: "idx_calendar_user_start")
  @@map("calendar_events")
}

// ── Document ──────────────────────────────────────────────

model Document {
  id           String    @id @default(uuid()) @db.Uuid
  gabineteId   String    @map("gabinete_id") @db.Uuid
  processoId   String?   @map("processo_id") @db.Uuid
  uploadedById String    @map("uploaded_by_id") @db.Uuid
  title        String    @db.VarChar(300)
  category     String    @db.VarChar(30) // DocumentCategory enum
  fileUrl      String    @map("file_url") @db.VarChar(500)
  fileSize     Int       @map("file_size") // Bytes
  mimeType     String    @map("mime_type") @db.VarChar(100)
  version      Int       @default(1)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete   Gabinete  @relation(fields: [gabineteId], references: [id])
  processo   Processo? @relation(fields: [processoId], references: [id])
  uploadedBy User      @relation("UploadedDocuments", fields: [uploadedById], references: [id])

  @@index([gabineteId], map: "idx_document_gabinete")
  @@index([gabineteId, processoId], map: "idx_document_gabinete_processo")
  @@map("documents")
}

// ── Audit Log (Append-Only) ──────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  gabineteId String   @map("gabinete_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(30) // AuditAction enum
  entity     String   @db.VarChar(30) // EntityType enum
  entityId   String?  @map("entity_id") @db.VarChar(50)
  oldValue   Json?    @map("old_value") @db.JsonB
  newValue   Json?    @map("new_value") @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  // NO updatedAt, NO deletedAt — append-only
  @@index([gabineteId], map: "idx_audit_gabinete")
  @@index([gabineteId, entity], map: "idx_audit_gabinete_entity")
  @@index([gabineteId, userId], map: "idx_audit_gabinete_user")
  @@index([createdAt], map: "idx_audit_created")
  @@map("audit_logs")
}

// ── AI Conversation ───────────────────────────────────────

model AIConversation {
  id         String    @id @default(uuid()) @db.Uuid
  gabineteId String    @map("gabinete_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  title      String?   @db.VarChar(300)
  context    String    @default("GERAL") @db.VarChar(20) // PROCESSO | PRAZO | GERAL | DOCUMENTO
  contextId  String?   @map("context_id") @db.Uuid
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete    @relation(fields: [gabineteId], references: [id])
  user     User        @relation(fields: [userId], references: [id])
  messages AIMessage[]

  @@index([gabineteId, userId], map: "idx_ai_conv_gabinete_user")
  @@map("ai_conversations")
}

// ── AI Message ────────────────────────────────────────────

model AIMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   @db.VarChar(20) // user | assistant | system
  content        String   @db.Text
  tokenCount     Int?     @map("token_count")
  model          String?  @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId], map: "idx_ai_msg_conversation")
  @@map("ai_messages")
}

// ── Subscription ──────────────────────────────────────────

model Subscription {
  id                   String    @id @default(uuid()) @db.Uuid
  gabineteId           String    @unique @map("gabinete_id") @db.Uuid
  plan                 String    @db.VarChar(20) // SubscriptionPlan enum
  status               String    @default("ACTIVE") @db.VarChar(20) // SubscriptionStatus enum
  currentPeriodStart   DateTime  @map("current_period_start") @db.Timestamptz
  currentPeriodEnd     DateTime  @map("current_period_end") @db.Timestamptz
  cancelledAt          DateTime? @map("cancelled_at") @db.Timestamptz
  stripeCustomerId     String?   @map("stripe_customer_id") @db.VarChar(100)
  stripeSubscriptionId String?   @map("stripe_subscription_id") @db.VarChar(100)
  multicaixaRef        String?   @map("multicaixa_ref") @db.VarChar(100)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])

  @@map("subscriptions")
}

// ── Usage Quota ───────────────────────────────────────────

model UsageQuota {
  id               String   @id @default(uuid()) @db.Uuid
  gabineteId       String   @unique @map("gabinete_id") @db.Uuid
  aiQueriesUsed    Int      @default(0) @map("ai_queries_used")
  docAnalysesUsed  Int      @default(0) @map("doc_analyses_used")
  storageUsedBytes BigInt   @default(0) @map("storage_used_bytes")
  periodStart      DateTime @map("period_start") @db.Timestamptz
  periodEnd        DateTime @map("period_end") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])

  @@map("usage_quotas")
}

// ── Time Entry (Timesheets) ───────────────────────────────

model TimeEntry {
  id              String    @id @default(uuid()) @db.Uuid
  gabineteId      String    @map("gabinete_id") @db.Uuid
  processoId      String    @map("processo_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  category        String    @db.VarChar(30) // TimeEntryCategory enum
  description     String?   @db.Text
  date            DateTime  @db.Date
  durationMinutes Int       @map("duration_minutes")
  billable        Boolean   @default(true)
  hourlyRate      Int?      @map("hourly_rate") // Centavos AKZ, if null inherits from Processo.feeAmount
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  processo Processo @relation(fields: [processoId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([gabineteId, date], map: "idx_timeentry_gabinete_date")
  @@index([gabineteId, processoId], map: "idx_timeentry_gabinete_processo")
  @@index([gabineteId, userId], map: "idx_timeentry_gabinete_user")
  @@map("time_entries")
}

// ── Expense (Despesas) ────────────────────────────────────

model Expense {
  id          String    @id @default(uuid()) @db.Uuid
  gabineteId  String    @map("gabinete_id") @db.Uuid
  processoId  String    @map("processo_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  category    String    @db.VarChar(30) // ExpenseCategory enum
  description String    @db.Text
  amount      Int // Centavos AKZ
  date        DateTime  @db.Date
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  processo Processo @relation(fields: [processoId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([gabineteId, date], map: "idx_expense_gabinete_date")
  @@index([gabineteId, processoId], map: "idx_expense_gabinete_processo")
  @@map("expenses")
}

// ── Notification (Sprint 7) ──────────────────────────────

model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  gabineteId   String    @map("gabinete_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  prazoId      String?   @map("prazo_id") @db.Uuid
  type         String    @db.VarChar(30)
  channel      String    @db.VarChar(20)
  status       String    @default("PENDING") @db.VarChar(20)
  subject      String?   @db.VarChar(300)
  body         String?   @db.Text
  metadata     Json?     @db.JsonB
  sentAt       DateTime? @map("sent_at") @db.Timestamptz
  errorMessage String?   @map("error_message") @db.Text
  readAt       DateTime? @map("read_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([gabineteId, userId], map: "idx_notification_user")
  @@index([prazoId], map: "idx_notification_prazo")
  @@index([createdAt], map: "idx_notification_created")
  @@map("notifications")
}

// ── Push Subscription (Web Push VAPID) ──────────────────

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @db.VarChar(2000)
  p256dh    String   @db.VarChar(500)
  auth      String   @db.VarChar(500)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_push_user")
  @@map("push_subscriptions")
}

// ── Notification Preferences ─────────────────────────────

model NotificationPreference {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  emailEnabled  Boolean  @default(true) @map("email_enabled")
  pushEnabled   Boolean  @default(true) @map("push_enabled")
  smsEnabled    Boolean  @default(false) @map("sms_enabled")
  smsOnlyUrgent Boolean  @default(true) @map("sms_only_urgent")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ── Task Column (Kanban Board) ───────────────────────────

model TaskColumn {
  id         String   @id @default(uuid()) @db.Uuid
  gabineteId String   @map("gabinete_id") @db.Uuid
  title      String   @db.VarChar(100)
  position   Int      @default(0)
  color      String?  @db.VarChar(7)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  tasks    Task[]

  @@index([gabineteId, position], map: "idx_taskcolumn_gabinete_pos")
  @@map("task_columns")
}

// ── Task (Kanban Card) ──────────────────────────────────

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  gabineteId  String    @map("gabinete_id") @db.Uuid
  columnId    String    @map("column_id") @db.Uuid
  title       String    @db.VarChar(500)
  description String?   @db.Text
  priority    String    @default("MEDIA") @db.VarChar(10)
  position    Int       @default(0)
  assigneeId  String?   @map("assignee_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  processoId  String?   @map("processo_id") @db.Uuid
  clienteId   String?   @map("cliente_id") @db.Uuid
  dueDate     DateTime? @map("due_date") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  labels      String[]  @default([])
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete  Gabinete        @relation(fields: [gabineteId], references: [id])
  column    TaskColumn      @relation(fields: [columnId], references: [id])
  assignee  User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User            @relation("TaskCreator", fields: [createdById], references: [id])
  processo  Processo?       @relation(fields: [processoId], references: [id])
  cliente   Cliente?        @relation(fields: [clienteId], references: [id])
  checklist TaskCheckItem[]
  comments  TaskComment[]

  @@index([gabineteId, columnId, position], map: "idx_task_column_pos")
  @@index([gabineteId, assigneeId], map: "idx_task_assignee")
  @@index([gabineteId, processoId], map: "idx_task_processo")
  @@map("tasks")
}

// ── Task Check Item (Checklist) ─────────────────────────

model TaskCheckItem {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  title     String   @db.VarChar(300)
  checked   Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId], map: "idx_checkitem_task")
  @@map("task_check_items")
}

// ── Task Comment ────────────────────────────────────────

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskComments", fields: [userId], references: [id])

  @@index([taskId], map: "idx_taskcomment_task")
  @@map("task_comments")
}

// ── Cliente Interaction (CRM Flow) ───────────────────────

model ClienteInteraction {
  id         String    @id @default(uuid()) @db.Uuid
  gabineteId String    @map("gabinete_id") @db.Uuid
  clienteId  String    @map("cliente_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  type       String    @db.VarChar(20) // CHAMADA, EMAIL, REUNIAO, WHATSAPP, VISITA
  notes      String?   @db.Text
  date       DateTime  @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])
  cliente  Cliente  @relation(fields: [clienteId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([gabineteId, clienteId], map: "idx_interaction_gabinete_cliente")
  @@map("cliente_interactions")
}

// ── Legislation Document (RAG) ───────────────────────────

model LegislationDocument {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(500)
  shortName String   @map("short_name") @db.VarChar(50)
  reference String   @db.VarChar(200)
  category  String   @db.VarChar(30)
  sourceUrl String?  @map("source_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  chunks LegislationChunk[]

  @@index([category], map: "idx_legislation_category")
  @@index([shortName], map: "idx_legislation_short_name")
  @@map("legislation_documents")
}

// ── Legislation Chunk (RAG embeddings) ───────────────────

model LegislationChunk {
  id         String                      @id @default(uuid()) @db.Uuid
  documentId String                      @map("document_id") @db.Uuid
  chunkIndex Int                         @map("chunk_index")
  title      String                      @db.VarChar(500)
  content    String                      @db.Text
  embedding  Unsupported("vector(768)")?
  tokenCount Int                         @map("token_count")
  createdAt  DateTime                    @default(now()) @map("created_at") @db.Timestamptz

  document LegislationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId], map: "idx_chunk_document")
  @@map("legislation_chunks")
}

// ═══════════════════════════════════════════════════════════
// Workflow Engine — dynamic stages for processos & projects
// ═══════════════════════════════════════════════════════════

// A reusable pipeline of stages configured per gabinete.
// Replaces the hardcoded PROCESSO_STAGES constant, letting firms
// add/remove stages like Tréplica / Quadruplica at will.
model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  gabineteId  String   @map("gabinete_id") @db.Uuid
  name        String   @db.VarChar(200)
  description String?  @db.Text
  scope       String   @db.VarChar(20) // 'PROCESSO' | 'PROJECT'
  appliesTo   String[] @default([]) @map("applies_to") // e.g. ['CIVEL','COMERCIAL'] or ['MA','COMPLIANCE']
  isDefault   Boolean  @default(false) @map("is_default")
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  gabinete  Gabinete        @relation(fields: [gabineteId], references: [id])
  stages    WorkflowStage[]
  processos Processo[]
  projects  Project[]

  @@index([gabineteId, scope], map: "idx_workflow_gabinete_scope")
  @@map("workflows")
}

model WorkflowStage {
  id             String   @id @default(uuid()) @db.Uuid
  workflowId     String   @map("workflow_id") @db.Uuid
  key            String   @db.VarChar(60) // slug estável: "replica", "treplica"
  label          String   @db.VarChar(100) // "Tréplica"
  position       Int      @default(0)
  color          String?  @db.VarChar(7)
  category       String?  @db.VarChar(60) // agrupamento visual: "ARTICULADOS"
  slaHours       Int?     @map("sla_hours")
  allowsParallel Boolean  @default(false) @map("allows_parallel")
  isTerminal     Boolean  @default(false) @map("is_terminal") // fase final (arquivo)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workflow  Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  instances ProcessoStageInstance[]

  @@unique([workflowId, key], map: "uq_stage_workflow_key")
  @@index([workflowId, position], map: "idx_stage_workflow_position")
  @@map("workflow_stages")
}

// A processo can be in N stages in parallel (e.g. "Réplica" + "Incidente").
// Replaces Processo.stage (kept as legacy for back-compat during migration).
model ProcessoStageInstance {
  id         String    @id @default(uuid()) @db.Uuid
  processoId String    @map("processo_id") @db.Uuid
  stageId    String    @map("stage_id") @db.Uuid
  status     String    @default("EM_CURSO") @db.VarChar(20) // PENDENTE|EM_CURSO|CUMPRIDO|SKIPPED
  enteredAt  DateTime  @default(now()) @map("entered_at") @db.Timestamptz
  exitedAt   DateTime? @map("exited_at") @db.Timestamptz
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  processo Processo      @relation(fields: [processoId], references: [id], onDelete: Cascade)
  stage    WorkflowStage @relation(fields: [stageId], references: [id])

  @@index([processoId, status], map: "idx_stageinst_processo_status")
  @@index([stageId], map: "idx_stageinst_stage")
  @@map("processo_stage_instances")
}

// ═══════════════════════════════════════════════════════════
// Legal Project — container for M&A, Compliance, DD, etc.
// A Project aggregates processos + tasks + milestones + budget.
// ═══════════════════════════════════════════════════════════
model Project {
  id             String    @id @default(uuid()) @db.Uuid
  gabineteId     String    @map("gabinete_id") @db.Uuid
  clienteId      String?   @map("cliente_id") @db.Uuid
  workflowId     String?   @map("workflow_id") @db.Uuid
  managerId      String    @map("manager_id") @db.Uuid
  sponsorId      String?   @map("sponsor_id") @db.Uuid
  code           String    @db.VarChar(30)
  name           String    @db.VarChar(300)
  category       String    @db.VarChar(30) // 'LITIGIO'|'MA'|'COMPLIANCE'|'DUE_DILIGENCE'|'CONTRATO'|'CONSULTORIA'|'OUTRO'
  status         String    @default("ACTIVO") @db.VarChar(20) // PROPOSTA|ACTIVO|EM_PAUSA|CONCLUIDO|CANCELADO
  healthStatus   String    @default("GREEN") @map("health_status") @db.VarChar(10) // GREEN|YELLOW|RED
  scope          String?   @db.Text
  objectives     String?   @db.Text
  risksJson      Json?     @map("risks_json")
  startDate      DateTime? @map("start_date") @db.Timestamptz
  endDate        DateTime? @map("end_date") @db.Timestamptz
  actualEndDate  DateTime? @map("actual_end_date") @db.Timestamptz
  budgetAmount   Int?      @map("budget_amount") // centavos
  budgetCurrency String    @default("AKZ") @map("budget_currency") @db.VarChar(3)
  tags           String[]  @default([])
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete   Gabinete           @relation(fields: [gabineteId], references: [id])
  cliente    Cliente?           @relation(fields: [clienteId], references: [id])
  workflow   Workflow?          @relation(fields: [workflowId], references: [id])
  manager    User               @relation("ProjectManager", fields: [managerId], references: [id])
  sponsor    User?              @relation("ProjectSponsor", fields: [sponsorId], references: [id])
  members    ProjectMember[]
  milestones ProjectMilestone[]
  processos  Processo[]

  @@unique([gabineteId, code], map: "uq_project_gabinete_code")
  @@index([gabineteId, status], map: "idx_project_gabinete_status")
  @@index([gabineteId, category], map: "idx_project_gabinete_category")
  @@index([gabineteId, managerId], map: "idx_project_gabinete_manager")
  @@index([gabineteId, clienteId], map: "idx_project_gabinete_cliente")
  @@map("projects")
}

model ProjectMember {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  role          String   @db.VarChar(20) // RACI: RESPONSIBLE|ACCOUNTABLE|CONSULTED|INFORMED
  allocationPct Int?     @map("allocation_pct")
  hourlyRate    Int?     @map("hourly_rate") // centavos/h override
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId], map: "uq_member_project_user")
  @@index([projectId], map: "idx_member_project")
  @@map("project_members")
}

model ProjectMilestone {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  title       String    @db.VarChar(300)
  description String?   @db.Text
  dueDate     DateTime  @map("due_date") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  dependsOnId String?   @map("depends_on_id") @db.Uuid
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dependsOn  ProjectMilestone?  @relation("MilestoneDeps", fields: [dependsOnId], references: [id])
  dependents ProjectMilestone[] @relation("MilestoneDeps")

  @@index([projectId, position], map: "idx_milestone_project_position")
  @@map("project_milestones")
}
