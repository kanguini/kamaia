// ═══════════════════════════════════════════════════════════
// Workflow Engine — dynamic stages for processos & projects
// ═══════════════════════════════════════════════════════════

// A reusable pipeline of stages configured per gabinete.
// Replaces the hardcoded PROCESSO_STAGES constant, letting firms
// add/remove stages (ex: Tréplica, Articulados Supervenientes) at will.
model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  gabineteId  String   @map("gabinete_id") @db.Uuid
  name        String   @db.VarChar(200)
  description String?  @db.Text
  scope       String   @db.VarChar(20) // 'PROCESSO' | 'PROJECT'
  appliesTo   String[] @default([]) @map("applies_to") // e.g. ['CIVEL','COMERCIAL'] or ['MA','COMPLIANCE']
  isDefault   Boolean  @default(false) @map("is_default")
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  gabinete  Gabinete        @relation(fields: [gabineteId], references: [id])
  stages    WorkflowStage[]
  processos Processo[]
  projects  Project[]

  @@index([gabineteId, scope], map: "idx_workflow_gabinete_scope")
  @@map("workflows")
}

model WorkflowStage {
  id             String   @id @default(uuid()) @db.Uuid
  workflowId     String   @map("workflow_id") @db.Uuid
  key            String   @db.VarChar(60) // slug estável: "replica", "treplica"
  label          String   @db.VarChar(100) // "Tréplica"
  position       Int      @default(0)
  color          String?  @db.VarChar(7)
  category       String?  @db.VarChar(60) // agrupamento visual: "ARTICULADOS"
  slaHours       Int?     @map("sla_hours")
  allowsParallel Boolean  @default(false) @map("allows_parallel")
  isTerminal     Boolean  @default(false) @map("is_terminal") // fase final (arquivo)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workflow  Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  instances ProcessoStageInstance[]

  @@unique([workflowId, key], map: "uq_stage_workflow_key")
  @@index([workflowId, position], map: "idx_stage_workflow_position")
  @@map("workflow_stages")
}

// A processo can be in N stages in parallel (e.g. "Réplica" + "Incidente").
// Replaces Processo.stage (kept as legacy for back-compat during migration).
model ProcessoStageInstance {
  id         String    @id @default(uuid()) @db.Uuid
  processoId String    @map("processo_id") @db.Uuid
  stageId    String    @map("stage_id") @db.Uuid
  status     String    @default("EM_CURSO") @db.VarChar(20) // PENDENTE|EM_CURSO|CUMPRIDO|SKIPPED
  enteredAt  DateTime  @default(now()) @map("entered_at") @db.Timestamptz
  exitedAt   DateTime? @map("exited_at") @db.Timestamptz
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  processo Processo      @relation(fields: [processoId], references: [id], onDelete: Cascade)
  stage    WorkflowStage @relation(fields: [stageId], references: [id])

  @@index([processoId, status], map: "idx_stageinst_processo_status")
  @@index([stageId], map: "idx_stageinst_stage")
  @@map("processo_stage_instances")
}

// ═══════════════════════════════════════════════════════════
// Legal Project — container for M&A, Compliance, DD, etc.
// A Project aggregates processos + tasks + milestones + budget.
// ═══════════════════════════════════════════════════════════
model Project {
  id             String    @id @default(uuid()) @db.Uuid
  gabineteId     String    @map("gabinete_id") @db.Uuid
  clienteId      String?   @map("cliente_id") @db.Uuid
  workflowId     String?   @map("workflow_id") @db.Uuid
  managerId      String    @map("manager_id") @db.Uuid
  sponsorId      String?   @map("sponsor_id") @db.Uuid
  code           String    @db.VarChar(30)
  name           String    @db.VarChar(300)
  category       String    @db.VarChar(30) // 'LITIGIO'|'MA'|'COMPLIANCE'|'DUE_DILIGENCE'|'CONTRATO'|'CONSULTORIA'|'OUTRO'
  status         String    @default("ACTIVO") @db.VarChar(20) // PROPOSTA|ACTIVO|EM_PAUSA|CONCLUIDO|CANCELADO
  healthStatus   String    @default("GREEN") @map("health_status") @db.VarChar(10) // GREEN|YELLOW|RED
  scope          String?   @db.Text
  objectives     String?   @db.Text
  risksJson      Json?     @map("risks_json")
  startDate      DateTime? @map("start_date") @db.Timestamptz
  endDate        DateTime? @map("end_date") @db.Timestamptz
  actualEndDate  DateTime? @map("actual_end_date") @db.Timestamptz
  budgetAmount   Int?      @map("budget_amount") // centavos
  budgetCurrency String    @default("AOA") @map("budget_currency") @db.VarChar(3)
  // PUBLIC = todos os membros do gabinete podem ler; MEMBERS_ONLY = apenas
  // members do projecto + SOCIO_GESTOR do gabinete. Default PUBLIC mantém
  // compat com o comportamento pré-Y.
  visibility     String    @default("PUBLIC") @db.VarChar(20)
  tags           String[]  @default([])
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete      Gabinete              @relation(fields: [gabineteId], references: [id])
  cliente       Cliente?              @relation(fields: [clienteId], references: [id])
  workflow      Workflow?             @relation(fields: [workflowId], references: [id])
  manager       User                  @relation("ProjectManager", fields: [managerId], references: [id])
  sponsor       User?                 @relation("ProjectSponsor", fields: [sponsorId], references: [id])
  members       ProjectMember[]
  milestones    ProjectMilestone[]
  processos     Processo[]
  tasks         Task[]
  documents     Document[]
  statusReports ProjectStatusReport[]
  invoices      Invoice[]

  @@unique([gabineteId, code], map: "uq_project_gabinete_code")
  @@index([gabineteId, status], map: "idx_project_gabinete_status")
  @@index([gabineteId, category], map: "idx_project_gabinete_category")
  @@index([gabineteId, managerId], map: "idx_project_gabinete_manager")
  @@index([gabineteId, clienteId], map: "idx_project_gabinete_cliente")
  @@map("projects")
}

model ProjectMember {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  role          String   @db.VarChar(20) // RACI: RESPONSIBLE|ACCOUNTABLE|CONSULTED|INFORMED
  allocationPct Int?     @map("allocation_pct")
  hourlyRate    Int?     @map("hourly_rate") // centavos/h override
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId], map: "uq_member_project_user")
  @@index([projectId], map: "idx_member_project")
  @@map("project_members")
}

model ProjectMilestone {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  title       String    @db.VarChar(300)
  description String?   @db.Text
  startDate   DateTime? @map("start_date") @db.Timestamptz
  dueDate     DateTime  @map("due_date") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  progress    Int       @default(0)
  // Orçamento planeado para esta fase em centavos. Usado como captura
  // antecipada — não altera ainda a curva ideal do burndown (que é
  // linear). Frontend valida soma ≤ Project.budgetAmount.
  budgetCents Int?      @map("budget_cents")
  dependsOnId String?   @map("depends_on_id") @db.Uuid
  position    Int       @default(0)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dependsOn  ProjectMilestone?  @relation("MilestoneDeps", fields: [dependsOnId], references: [id])
  dependents ProjectMilestone[] @relation("MilestoneDeps")
  tasks      Task[]
  documents  Document[]

  @@index([projectId, position], map: "idx_milestone_project_position")
  @@map("project_milestones")
}

// ═══════════════════════════════════════════════════════════
// Custom Project Templates — editable per gabinete
//
// Shipped playbooks (M&A, Compliance, DD, Contrato, Consultoria) live in
// code (shared-types) as read-only system templates. When a gabinete wants
// to tweak one — add a milestone, change durations — it "duplicates" the
// system template into this table, editable at will. Milestones are kept
// as JSON for simplicity (they're small, structured, and always read as a
// whole).
// ═══════════════════════════════════════════════════════════
model ProjectTemplateCustom {
  id                  String   @id @default(uuid()) @db.Uuid
  gabineteId          String   @map("gabinete_id") @db.Uuid
  category            String   @db.VarChar(30)
  name                String   @db.VarChar(200)
  description         String?  @db.Text
  scopeBlurb          String?  @map("scope_blurb") @db.Text
  objectivesBlurb     String?  @map("objectives_blurb") @db.Text
  defaultDurationDays Int      @default(30) @map("default_duration_days")
  // Milestones as JSON: [{title, description?, startDayOffset, dueDayOffset}]
  milestones          Json
  basedOnSystemId     String?  @map("based_on_system_id") @db.VarChar(60)
  isArchived          Boolean  @default(false) @map("is_archived")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  gabinete Gabinete @relation(fields: [gabineteId], references: [id])

  @@index([gabineteId, category], map: "idx_tplcustom_gabinete_category")
  @@map("project_templates_custom")
}

// ═══════════════════════════════════════════════════════════
// Weekly Project Status Reports
//
// One snapshot per project per week. Rows are auto-generated by a Monday
// cron job but users can also create ad-hoc reports and edit the narrative
// fields (risks, summary, health override).
// ═══════════════════════════════════════════════════════════
model ProjectStatusReport {
  id                  String    @id @default(uuid()) @db.Uuid
  projectId           String    @map("project_id") @db.Uuid
  weekStart           DateTime  @map("week_start") @db.Timestamptz
  healthStatus        String    @default("GREEN") @map("health_status") @db.VarChar(10)
  budgetSnapshot      Int?      @map("budget_snapshot")
  actualSpentSnapshot Int?      @map("actual_spent_snapshot")
  idealSpentSnapshot  Int?      @map("ideal_spent_snapshot")
  hoursLoggedMinutes  Int       @default(0) @map("hours_logged_minutes")
  milestonesTotal     Int       @default(0) @map("milestones_total")
  milestonesCompleted Int       @default(0) @map("milestones_completed")
  milestonesOverdue   Int       @default(0) @map("milestones_overdue")
  risks               Json? // [{ title, severity: 'LOW'|'MEDIUM'|'HIGH'|'CRITICAL', mitigation? }]
  summary             String?   @db.Text
  createdById         String    @map("created_by_id") @db.Uuid
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@unique([projectId, weekStart], map: "uq_report_project_week")
  @@index([projectId, weekStart(sort: Desc)], map: "idx_report_project_week")
  @@map("project_status_reports")
}

// ═══════════════════════════════════════════════════════════
// Invoicing — core business model for solo / small gabinetes.
//
// An Invoice aggregates billable TimeEntries and Expenses into a
// client-facing document. Entries are locked (invoiceId foreign key)
// the moment they are committed to an invoice so they can't be
// double-billed. The invoice flows through a lightweight lifecycle:
//   DRAFT → SENT → PAID | PARTIALLY_PAID | OVERDUE | VOID
// ═══════════════════════════════════════════════════════════
model Invoice {
  id          String    @id @default(uuid()) @db.Uuid
  gabineteId  String    @map("gabinete_id") @db.Uuid
  clienteId   String    @map("cliente_id") @db.Uuid
  processoId  String?   @map("processo_id") @db.Uuid
  projectId   String?   @map("project_id") @db.Uuid
  number      String    @db.VarChar(30) // "2026/0001"
  issueDate   DateTime  @default(now()) @map("issue_date") @db.Timestamptz
  dueDate     DateTime? @map("due_date") @db.Timestamptz
  status      String    @default("DRAFT") @db.VarChar(20)
  currency    String    @default("AOA") @db.VarChar(3)
  subtotal    Int       @default(0)
  taxRate     Float     @default(14.0) @map("tax_rate") // IVA Angola geral = 14%
  taxAmount   Int       @default(0) @map("tax_amount")
  total       Int       @default(0)
  amountPaid  Int       @default(0) @map("amount_paid")
  notes       String?   @db.Text
  termsText   String?   @map("terms_text") @db.Text
  sentAt      DateTime? @map("sent_at") @db.Timestamptz
  paidAt      DateTime? @map("paid_at") @db.Timestamptz
  voidedAt    DateTime? @map("voided_at") @db.Timestamptz
  createdById String    @map("created_by_id") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  gabinete    Gabinete         @relation(fields: [gabineteId], references: [id])
  cliente     Cliente          @relation(fields: [clienteId], references: [id])
  processo    Processo?        @relation(fields: [processoId], references: [id])
  project     Project?         @relation(fields: [projectId], references: [id])
  createdBy   User             @relation("InvoiceCreator", fields: [createdById], references: [id])
  items       InvoiceItem[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  payments    InvoicePayment[]

  @@unique([gabineteId, number], map: "uq_invoice_gabinete_number")
  @@index([gabineteId, status], map: "idx_invoice_gabinete_status")
  @@index([gabineteId, clienteId], map: "idx_invoice_gabinete_cliente")
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  kind        String  @db.VarChar(20) // TIME | EXPENSE | CUSTOM
  description String  @db.VarChar(500)
  quantity    Float   @default(1) // hours for TIME, 1 for EXPENSE/CUSTOM
  unitPrice   Int     @map("unit_price") // centavos
  total       Int // centavos (quantity × unitPrice, rounded)
  sourceId    String? @map("source_id") @db.Uuid // original TimeEntry or Expense id
  position    Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, position], map: "idx_item_invoice_position")
  @@map("invoice_items")
}

model InvoicePayment {
  id           String   @id @default(uuid()) @db.Uuid
  invoiceId    String   @map("invoice_id") @db.Uuid
  amount       Int // centavos
  paidAt       DateTime @map("paid_at") @db.Timestamptz
  method       String?  @db.VarChar(30) // 'TRANSFERENCIA' | 'DINHEIRO' | 'CHEQUE' | 'OUTRO'
  reference    String?  @db.VarChar(120)
  notes        String?  @db.Text
  recordedById String   @map("recorded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User    @relation("PaymentRecorder", fields: [recordedById], references: [id])

  @@index([invoiceId], map: "idx_payment_invoice")
  @@map("invoice_payments")
}

// ═══════════════════════════════════════════════════════════
// Feriados / Holidays — business-day calculations for prazos
//
// System-wide Angolan public holidays are auto-seeded (gabineteId null).
// A gabinete can add local/municipal overrides with its own gabineteId.
// ═══════════════════════════════════════════════════════════
model Holiday {
  id         String   @id @default(uuid()) @db.Uuid
  gabineteId String?  @map("gabinete_id") @db.Uuid // null = system holiday (applies to all)
  name       String   @db.VarChar(200)
  date       DateTime @db.Date
  kind       String   @default("NATIONAL") @db.VarChar(20) // NATIONAL | MUNICIPAL | RELIGIOUS | OTHER
  recurring  Boolean  @default(false) // if true: date month/day repeats every year
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  gabinete Gabinete? @relation(fields: [gabineteId], references: [id])

  @@unique([gabineteId, date, name], map: "uq_holiday_gabinete_date_name")
  @@index([date], map: "idx_holiday_date")
  @@index([gabineteId], map: "idx_holiday_gabinete")
  @@map("holidays")
}

// ═══════════════════════════════════════════════════════════
// PublicContactSubmission — marketing-site contact form
//
// Lands outside the gabinete isolation boundary: these are *prospects*,
// not tenants. We keep them to (a) avoid data loss if email delivery
// fails, (b) enable pipeline / CRM export, (c) provide an audit trail
// for compliance (Lei 22/11 — protecção de dados pessoais de Angola).
//
// Writes are public (throttled at controller level). Reads require
// admin auth — add a guarded endpoint when needed.
// ═══════════════════════════════════════════════════════════
model PublicContactSubmission {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(200)
  email       String    @db.VarChar(255)
  phone       String?   @db.VarChar(50)
  gabinete    String?   @db.VarChar(200)
  plan        String?   @db.VarChar(50)
  message     String    @db.Text
  // Affirmative consent (RGPD / Lei 22/11 de Angola). Stored as a
  // timestamp so we can prove WHEN consent was given, not just that
  // it was ticked. Null means the checkbox was not submitted.
  consentedAt DateTime? @map("consented_at") @db.Timestamptz
  // Best-effort request metadata for fraud / rate-limit forensics.
  ipAddress   String?   @map("ip_address") @db.VarChar(50)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  // Outcome of email delivery via Resend.
  // PENDING | SENT | FAILED
  emailStatus String    @default("PENDING") @map("email_status") @db.VarChar(20)
  emailError  String?   @map("email_error") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt], map: "idx_public_contact_created")
  @@index([email], map: "idx_public_contact_email")
  @@map("public_contact_submissions")
}
