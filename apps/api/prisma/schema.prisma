// ═══════════════════════════════════════════════════════════
// KAMAIA CLM — Database Schema
// Contract Lifecycle Management for Angola & PALOP
// Platform: PostgreSQL 16 + pgvector
// ═══════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgvector(map: "vector", schema: "public")]
}

// ═══════════════════════════════════════════════════════════
// TENANT & USERS
// ═══════════════════════════════════════════════════════════

enum TenantPlan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
  AGENCY  // sociedade de advogados — pode ter sub-tenants
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

model Tenant {
  id              String       @id @default(uuid()) @db.Uuid
  slug            String       @unique @db.VarChar(80)
  nome            String       @db.VarChar(200)
  nif             String?      @db.VarChar(20)
  email           String?      @db.VarChar(200)
  telefone        String?      @db.VarChar(30)
  morada          Json?
  logoUrl         String?      @map("logo_url") @db.VarChar(500)

  plan            TenantPlan   @default(STARTER)
  status          TenantStatus @default(TRIAL)

  // Hierarchy: AGENCY plan can have sub-tenants
  parentTenantId  String?      @map("parent_tenant_id") @db.Uuid
  parentTenant    Tenant?      @relation("TenantHierarchy", fields: [parentTenantId], references: [id])
  subTenants      Tenant[]     @relation("TenantHierarchy")

  // Country / locale
  country         String       @default("AO") @db.VarChar(2)
  locale          String       @default("pt-AO") @db.VarChar(10)
  timezone        String       @default("Africa/Luanda") @db.VarChar(50)

  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz

  memberships     Membership[]
  entidades       Entidade[]
  carteiras       Carteira[]
  tiposContrato   TipoContrato[]
  templates       Template[]
  clausulas       Clausula[]
  contratos       Contrato[]
  documents       Document[]
  importacaoLotes ImportacaoLote[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  aiConversations AIConversation[]
  subscription    Subscription?
  usageQuota      UsageQuota?
  apiKeys         ApiKey[]
  webhooks        Webhook[]
  backupExports   BackupExport[]
  agendaEventos   AgendaEvento[]
  tarefas         Tarefa[]

  @@index([parentTenantId])
  @@index([slug])
  @@map("tenants")
}

enum Role {
  ADMIN
  LEGAL_LEAD
  CONTRACT_MANAGER
  BUSINESS_USER
  VIEWER
  EXTERNAL
}

model User {
  id              String        @id @default(uuid()) @db.Uuid
  email           String        @unique @db.VarChar(200)
  passwordHash    String?       @map("password_hash") @db.VarChar(200)
  firstName       String        @map("first_name") @db.VarChar(100)
  lastName        String        @map("last_name") @db.VarChar(100)
  phone           String?       @db.VarChar(30)
  avatarUrl       String?       @map("avatar_url") @db.VarChar(500)
  provider        String        @default("credentials") @db.VarChar(20)
  providerId      String?       @map("provider_id") @db.VarChar(200)
  isActive        Boolean       @default(true) @map("is_active")
  emailVerifiedAt DateTime?     @map("email_verified_at") @db.Timestamptz
  lastLoginAt     DateTime?     @map("last_login_at") @db.Timestamptz
  failedLoginCount Int          @default(0) @map("failed_login_count")
  lockedUntil     DateTime?     @map("locked_until") @db.Timestamptz

  /// Password reset — SHA-256 hash de token raw. Mesma técnica que
  /// invite tokens: prefix de 8 chars para debug + hash de 64. TTL
  /// 1h. Limpo a zero após uso ou expiração.
  resetTokenHash   String?   @unique @map("reset_token_hash") @db.VarChar(64)
  resetTokenPrefix String?   @map("reset_token_prefix") @db.VarChar(20)
  resetExpiresAt   DateTime? @map("reset_expires_at") @db.Timestamptz

  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  memberships     Membership[]
  sessions        UserSession[]
  notifications   Notification[]
  pushSubscriptions PushSubscription[]
  aiConversations AIConversation[]
  tarefas         Tarefa[]

  @@index([email])
  @@index([resetTokenHash])
  @@map("users")
}

model Membership {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  role        Role
  isDefault   Boolean  @default(false) @map("is_default")
  invitedBy   String?  @map("invited_by") @db.Uuid
  invitedAt   DateTime? @map("invited_at") @db.Timestamptz
  acceptedAt  DateTime? @map("accepted_at") @db.Timestamptz

  /// AUDIT fix: magic-link invite token. Hash SHA-256 do raw token
  /// (mesma técnica usada em ContratoColaborador), com TTL.
  inviteTokenHash   String?   @unique @map("invite_token_hash") @db.VarChar(64)
  inviteTokenPrefix String?   @map("invite_token_prefix") @db.VarChar(20)
  inviteExpiresAt   DateTime? @map("invite_expires_at") @db.Timestamptz

  /// AUDIT fix: soft-delete em vez de hard. Audit trail preserva
  /// porquê alguém foi removido + permite re-adicionar mantendo histórico.
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([inviteTokenHash])
  @@map("memberships")
}

model UserSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tokenHash    String   @unique @map("token_hash") @db.VarChar(200)
  userAgent    String?  @map("user_agent") @db.Text
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ═══════════════════════════════════════════════════════════
// ENTIDADES (Counterparties / Parties)
// ═══════════════════════════════════════════════════════════

enum EntidadeTipo {
  PESSOA_SINGULAR
  PESSOA_COLECTIVA
}

enum EntidadeNacionalidadeCambial {
  RESIDENTE      // residente cambial em Angola
  NAO_RESIDENTE
}

model Entidade {
  id                       String                       @id @default(uuid()) @db.Uuid
  tenantId                 String                       @map("tenant_id") @db.Uuid
  tipo                     EntidadeTipo
  nome                     String                       @db.VarChar(300)
  nomeComercial            String?                      @map("nome_comercial") @db.VarChar(300)
  nif                      String?                      @db.VarChar(20)
  numeroBI                 String?                      @map("numero_bi") @db.VarChar(30)
  matriculaRC              String?                      @map("matricula_rc") @db.VarChar(50)
  nacionalidadeCambial     EntidadeNacionalidadeCambial @default(RESIDENTE) @map("nacionalidade_cambial")
  /// E.5: instituição financeira (banco, seguradora, leasing,
  /// microfinanças). Activa regras compliance específicas BNA.
  isInstituicaoFinanceira  Boolean                      @default(false) @map("is_instituicao_financeira")
  sectorActividade         String?                      @map("sector_actividade") @db.VarChar(100)
  morada                   Json?
  paisResidencia           String                       @default("AO") @map("pais_residencia") @db.VarChar(2)
  observacoes              String?                      @db.Text

  // ─── Pessoa singular ─────────────────────────────────────
  /// Estado civil — relevante para alienação de bens (Código Civil
  /// arts. 1678ss exige consentimento do cônjuge em determinados
  /// regimes). Só faz sentido para PESSOA_SINGULAR.
  estadoCivil              String?                      @map("estado_civil") @db.VarChar(40)
  regimeBens               String?                      @map("regime_bens") @db.VarChar(40)
  profissao                String?                      @db.VarChar(100)
  /// Data de validade do BI ou passaporte (lembrete proactivo
  /// quando expira durante a vigência de um contrato).
  biEmitidoEm              DateTime?                    @map("bi_emitido_em") @db.Date
  biValidoAte              DateTime?                    @map("bi_valido_ate") @db.Date
  biEmissor                String?                      @map("bi_emissor") @db.VarChar(100)

  // ─── Pessoa colectiva ────────────────────────────────────
  /// Forma jurídica — Lda, SA, EI, etc (Lei n.º 1/04). Determina
  /// capital social mínimo, órgãos sociais e responsabilidade dos
  /// sócios. Só faz sentido para PESSOA_COLECTIVA.
  formaJuridica            String?                      @map("forma_juridica") @db.VarChar(40)
  /// Capital social em centavos (BigInt — nunca floats para valores
  /// monetários, regra do projecto).
  capitalSocialCentavos    BigInt?                      @map("capital_social_centavos")
  capitalSocialMoeda       String?                      @map("capital_social_moeda") @db.VarChar(3)
  objectoSocial            String?                      @map("objecto_social") @db.Text
  dataConstituicao         DateTime?                    @map("data_constituicao") @db.Date

  // FTS
  searchVector             Unsupported("tsvector")?     @map("search_vector")

  createdAt                DateTime                     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime                     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?                    @map("deleted_at") @db.Timestamptz

  tenant                   Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactos                EntidadeContacto[]
  documentosKYC            EntidadeDocumentoKYC[]
  partesEmContratos        ContratoParte[]

  @@index([tenantId])
  @@index([tenantId, nome])
  @@index([tenantId, nif])
  @@index([searchVector], type: Gin)
  @@map("entidades")
}

model EntidadeContacto {
  id          String   @id @default(uuid()) @db.Uuid
  entidadeId  String   @map("entidade_id") @db.Uuid
  nome        String   @db.VarChar(200)
  cargo       String?  @db.VarChar(100)
  email       String?  @db.VarChar(200)
  telefone    String?  @db.VarChar(30)
  isPrincipal Boolean  @default(false) @map("is_principal")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  entidade    Entidade @relation(fields: [entidadeId], references: [id], onDelete: Cascade)

  @@index([entidadeId])
  @@map("entidade_contactos")
}

model EntidadeDocumentoKYC {
  id           String   @id @default(uuid()) @db.Uuid
  entidadeId   String   @map("entidade_id") @db.Uuid
  tipo         String   @db.VarChar(60)  // CERTIDAO_COMERCIAL, BI, PROCURACAO, AML, ...
  numero       String?  @db.VarChar(100)
  emitidoEm    DateTime? @map("emitido_em") @db.Date
  validoAte    DateTime? @map("valido_ate") @db.Date
  documentId   String?  @map("document_id") @db.Uuid
  observacoes  String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  entidade     Entidade @relation(fields: [entidadeId], references: [id], onDelete: Cascade)

  @@index([entidadeId])
  @@map("entidade_documentos_kyc")
}

// ═══════════════════════════════════════════════════════════
// CARTEIRA (optional grouping)
// ═══════════════════════════════════════════════════════════

model Carteira {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  nome        String     @db.VarChar(200)
  descricao   String?    @db.Text
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contratos   Contrato[]

  @@index([tenantId])
  @@map("carteiras")
}

// ═══════════════════════════════════════════════════════════
// CATÁLOGO: TIPO DE CONTRATO + TGIS
// ═══════════════════════════════════════════════════════════

model TipoContrato {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String?        @map("tenant_id") @db.Uuid  // null = catálogo global
  codigo              String         @db.VarChar(80)
  nome                String         @db.VarChar(200)
  categoria           String         @db.VarChar(60)  // PRE_CONTRATO, SERVICOS, BENS, IMOBILIARIO, FINANCEIRO, TRABALHO, IP
  descricao           String?        @db.Text

  // Default regulatory triggers (overridable per contract)
  tgisVerbaNumero     String?        @map("tgis_verba_numero") @db.VarChar(20)
  requerNotario       Boolean        @default(false) @map("requer_notario")
  registosRequeridos  String[]       @map("registos_requeridos")  // ex: ["REGISTO_PREDIAL"]
  gatilhoBNA          Json?          @map("gatilho_bna")
  retencaoIRTpadrao   Boolean        @default(false) @map("retencao_irt_padrao")
  clausulasObrigatorias String[]     @map("clausulas_obrigatorias")  // ex: ["FORO", "LEI_APLICAVEL"]

  templatePadraoId    String?        @map("template_padrao_id") @db.Uuid
  isActive            Boolean        @default(true) @map("is_active")

  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  tenant              Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contratos           Contrato[]
  templates           Template[]
  customFields        CustomFieldDefinition[]

  @@unique([tenantId, codigo])
  @@index([categoria])
  @@map("tipos_contrato")
}

// ═══════════════════════════════════════════════════════════
// CUSTOM FIELDS — schema dinâmico por TipoContrato
// ═══════════════════════════════════════════════════════════
//
// Permite que cada TipoContrato defina os SEUS campos extra (ex:
// Commercial Lease → "Área (m²)", "Renda mensal", "Caução"; NDA →
// "Período confidencialidade"; etc.). Evita ter um schema fixo com
// dezenas de campos "—" para cada tipo.
//
// O Compliance Engine continua a operar APENAS sobre campos
// hardcoded do `Contrato` (regras determinísticas, auditáveis).
// Custom fields são metadata visualizada na UI; não disparam regras.

enum CustomFieldType {
  STRING    // input texto curto
  TEXT      // textarea
  NUMBER    // input numérico
  DATE      // date picker
  BOOLEAN   // toggle
  SELECT    // dropdown com options
  MONEY     // valor + moeda
  ADDRESS   // morada estruturada (rua, cidade, província, país)
}

model CustomFieldDefinition {
  id              String          @id @default(uuid()) @db.Uuid
  tipoContratoId  String          @map("tipo_contrato_id") @db.Uuid
  /// Chave identificadora — só caracteres alfanuméricos + underscore.
  /// Usado como key estável (não muda quando o label é renomeado).
  key             String          @db.VarChar(60)
  label           String          @db.VarChar(120)
  hint            String?         @db.VarChar(400)
  type            CustomFieldType
  /// Para SELECT: array de strings. Para MONEY: { moedas: ["AOA", "USD"] }.
  /// Para outros tipos: null.
  options         Json?
  required        Boolean         @default(false)
  ordem           Int             @default(0)
  isActive        Boolean         @default(true) @map("is_active")

  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz

  tipoContrato    TipoContrato    @relation(fields: [tipoContratoId], references: [id], onDelete: Cascade)
  valores         ContratoCustomFieldValue[]

  @@unique([tipoContratoId, key])
  @@index([tipoContratoId, ordem])
  @@map("custom_field_definitions")
}

/// Onda B.RACE.8 — DECISÃO documentada sobre soft delete:
///
/// CLAUDE.md exige soft-delete para "dados de negócio". Custom field
/// values são state mutável (utilizador edita "Área m²" de 120 para
/// 200) — não dados append-only.
///
/// Optámos por NÃO ter `deletedAt`. Razões:
///   - O histórico de mudanças vive no `audit_log` (writeable em
///     B.RACE.7 — capturará before/after numa sprint futura)
///   - upsert pattern com `(contratoId, fieldId)` único requer que
///     o delete-then-recreate funcione; soft-delete obrigaria a
///     filter EVERY query por `deletedAt IS NULL`
///   - Limpar um valor = utilizador quer 0/null, não preservar
///
/// Quando o utilizador "limpa" um campo no drawer, o frontend
/// omite-o do payload (linha drawer:115) — o valor persiste mas
/// nunca vai ao backend para apagar. Isto é uma decisão UX
/// consciente: explicitamos no comentário do drawer.
///
/// Se aparecer requisito legal/regulatório de retenção de valores
/// históricos (auditoria fiscal angolana, e.g.), aí adicionamos
/// deletedAt — mas apenas se justificado por requisito específico,
/// não por consistency-policy global.
model ContratoCustomFieldValue {
  id            String                @id @default(uuid()) @db.Uuid
  contratoId    String                @map("contrato_id") @db.Uuid
  fieldId       String                @map("field_id") @db.Uuid
  /// Payload typed conforme o `field.type`. Valida no service antes
  /// de gravar — JSON arbitrário deixaria entrar lixo.
  ///   STRING/TEXT → { v: string }
  ///   NUMBER → { v: number }
  ///   DATE → { v: "YYYY-MM-DD" }
  ///   BOOLEAN → { v: boolean }
  ///   SELECT → { v: string } (uma das options)
  ///   MONEY → { v: number, moeda: string }  // v em unidades; centavos só se quisermos uniformidade
  ///   ADDRESS → { rua, cidade, provincia, pais }
  value         Json

  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  contrato      Contrato              @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  field         CustomFieldDefinition @relation(fields: [fieldId], references: [id])

  @@unique([contratoId, fieldId])
  @@index([fieldId])
  @@map("contrato_custom_field_values")
}

model TGISVerba {
  numero          String    @id @db.VarChar(20)
  descricao       String    @db.Text
  tipoTaxa        String    @map("tipo_taxa") @db.VarChar(20)  // PERCENTAGEM | VALOR_FIXO
  taxaValor       String    @map("taxa_valor") @db.VarChar(100)  // ex "0.5", "1000"
  taxaUnidade     String?   @map("taxa_unidade") @db.VarChar(20)  // AKZ, %, ‰
  baseRegra       Json?     @map("base_regra")
  responsavelLiquidacao String? @map("responsavel_liquidacao") @db.VarChar(60)
  referenciaLegal String    @map("referencia_legal") @db.Text
  vigenteDesde    DateTime  @map("vigente_desde") @db.Date
  vigenteAte      DateTime? @map("vigente_ate") @db.Date

  @@map("tgis_verbas")
}

// ═══════════════════════════════════════════════════════════
// BIBLIOTECA: TEMPLATES + CLÁUSULAS
// ═══════════════════════════════════════════════════════════

model Template {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  tipoId          String      @map("tipo_id") @db.Uuid
  nome            String      @db.VarChar(200)
  descricao       String?     @db.Text
  versao          Int         @default(1)
  conteudo        String      @db.Text   // markdown
  metadata        Json?
  idiomas         String[]    @default(["pt-AO"])
  isActive        Boolean     @default(true) @map("is_active")

  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  createdBy       String?     @map("created_by") @db.Uuid
  /// AUDIT fix: soft-delete (regra "nunca DELETE físico em dados de
  /// negócio" do CLAUDE.md). isActive era flag de visibilidade; agora
  /// distinguimos archived (isActive=false) de deleted (deletedAt!=null).
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tipo            TipoContrato @relation(fields: [tipoId], references: [id])

  @@index([tenantId, tipoId])
  @@map("templates")
}

model Clausula {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  categoria        String   @db.VarChar(60)  // FORO, LEI_APLICAVEL, LIMITACAO_RESPONSABILIDADE, ...
  titulo           String   @db.VarChar(200)
  conteudo         String   @db.Text
  leiAplicavelArt  String?  @map("lei_aplicavel_art") @db.VarChar(300)
  tags             String[] @default([])
  /// Códigos de TipoContrato a que a cláusula se aplica explicitamente.
  /// Lista vazia = aplicável a qualquer tipo. Usado pelo IaDraftingService
  /// para seleccionar contexto preciso ao invés do filter best-effort por tags.
  tipoContratoCodigos String[] @default([]) @map("tipo_contrato_codigos")
  idioma           String   @default("pt-AO") @db.VarChar(10)
  usoCount         Int      @default(0) @map("uso_count")
  origemContratoId String?  @map("origem_contrato_id") @db.Uuid
  isApproved       Boolean  @default(false) @map("is_approved")

  searchVector     Unsupported("tsvector")? @map("search_vector")

  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, categoria])
  @@index([tipoContratoCodigos], type: Gin)
  @@index([searchVector], type: Gin)
  @@map("clausulas")
}

// ═══════════════════════════════════════════════════════════
// CONTRATO — núcleo
// ═══════════════════════════════════════════════════════════

enum ContratoEstado {
  INTAKE
  DRAFTING
  REV_INTERNA
  REV_CLIENTE
  EM_NEGOCIACAO
  APROVACAO
  PRONTO_ASSINATURA
  ASSINADO
  POS_ASSINATURA
  ACTIVO
  EM_DISPUTA
  EM_ADENDA
  EM_TERMINACAO
  TERMINADO
  ARQUIVADO
  REPOSITORIO  // importado já assinado
  CANCELADO
}

enum ContratoOrigem {
  CRIADO_INTERNAMENTE
  IMPORTADO_REPOSITORIO
  RECEBIDO_CONTRAPARTE
  ADENDA
}

model Contrato {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  numeroInterno       String           @map("numero_interno") @db.VarChar(50)
  titulo              String           @db.VarChar(300)
  descricao           String?          @db.Text

  tipoId              String           @map("tipo_id") @db.Uuid
  carteiraId          String?          @map("carteira_id") @db.Uuid
  parentContratoId    String?          @map("parent_contrato_id") @db.Uuid

  estado              ContratoEstado   @default(INTAKE)
  origem              ContratoOrigem
  modoEngajamento     String?          @map("modo_engajamento") @db.VarChar(20)  // A, B, C, D

  // Valores
  valor               BigInt?
  moeda               String?          @db.VarChar(3)
  valorEmAKZ          BigInt?          @map("valor_em_akz")  // conversão para análise
  taxaCambio          Decimal?         @map("taxa_cambio") @db.Decimal(18, 6)

  // Lei + foro
  leiAplicavel        String?          @map("lei_aplicavel") @db.VarChar(100)
  foro                String?          @db.VarChar(200)

  // Datas-chave principais (denormalizadas para indexação rápida)
  dataAssinatura      DateTime?        @map("data_assinatura") @db.Date
  dataInicioVigencia  DateTime?        @map("data_inicio_vigencia") @db.Date
  dataTermo           DateTime?        @map("data_termo") @db.Date
  renovacaoAutomatica Boolean          @default(false) @map("renovacao_automatica")
  /// Duração de cada ciclo de renovação tácita, em meses. Necessário
  /// para o motor calcular o novo `dataTermo` automaticamente.
  /// Quando NULL e `renovacaoAutomatica=true`, o motor recusa-se a
  /// renovar e produz `RENOVACAO_FALHOU` para o operador completar.
  prazoRenovacaoMeses Int?             @map("prazo_renovacao_meses")
  janelaDenunciaDias  Int?             @map("janela_denuncia_dias")
  prazoIndeterminado  Boolean          @default(false) @map("prazo_indeterminado")

  /// Denúncia tempestiva — quando preenchido, a renovação automática
  /// é bloqueada. O motor verifica isto antes de qualquer renovação.
  denunciaEm          DateTime?        @map("denuncia_em") @db.Timestamptz
  denunciaPorUserId   String?          @map("denuncia_por_user_id") @db.Uuid
  denunciaMotivo      String?          @map("denuncia_motivo") @db.Text

  // Override de gatilhos regulatórios (caso o tipo não cubra)
  overrideNotario     Boolean?         @map("override_notario")
  overrideRegistos    String[]         @map("override_registos")

  responsavelId       String?          @map("responsavel_id") @db.Uuid

  searchVector        Unsupported("tsvector")? @map("search_vector")

  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  createdBy           String?          @map("created_by") @db.Uuid
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tipo                TipoContrato     @relation(fields: [tipoId], references: [id])
  carteira            Carteira?        @relation(fields: [carteiraId], references: [id])
  parent              Contrato?        @relation("Adendas", fields: [parentContratoId], references: [id])
  adendas             Contrato[]       @relation("Adendas")

  versoes             ContratoVersao[]
  partes              ContratoParte[]
  datasChave          ContratoDataChave[]
  obrigacoes          ContratoObrigacao[]
  actosRegulatorios   ContratoActoRegulatorio[]
  negociacaoPontos    ContratoNegociacaoPonto[]
  eventos             ContratoEvento[]
  terminacao          ContratoTerminacao?
  documentos          Document[]
  colaboradores       ContratoColaborador[]
  comentarios         ContratoComentario[]
  assinaturas         ContratoAssinatura[]
  customFieldValues   ContratoCustomFieldValue[]
  agendaEventos       AgendaEvento[]
  tarefas             Tarefa[]

  @@unique([tenantId, numeroInterno])
  @@index([tenantId, estado])
  @@index([tenantId, dataTermo])
  @@index([tenantId, tipoId])
  @@index([tenantId, responsavelId])
  @@index([tenantId, carteiraId])
  @@index([parentContratoId])
  // PERF: serve a lista por defeito (ORDER BY created_at, id) e as
  // contagens/série temporal do dashboard por createdAt.
  @@index([tenantId, createdAt, id])
  // PERF: serve "recentes" do dashboard (ORDER BY updated_at DESC).
  @@index([tenantId, updatedAt])
  // PERF (C1): serve o scan global do motor de renovação
  // (estado=ACTIVO AND data_termo<=hoje), que não tem tenantId leading.
  @@index([estado, dataTermo])
  @@index([searchVector], type: Gin)
  @@map("contratos")
}

// ═══════════════════════════════════════════════════════════
// VERSÕES
// ═══════════════════════════════════════════════════════════

enum VersaoDireccao {
  INTERNA
  ENVIADO_CLIENTE
  RECEBIDO_CLIENTE
  ENVIADO_CONTRAPARTE
  RECEBIDO_CONTRAPARTE
  ASSINADO_FINAL
}

enum ExtracaoStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  SKIPPED
}

model ContratoVersao {
  id              String         @id @default(uuid()) @db.Uuid
  contratoId      String         @map("contrato_id") @db.Uuid
  versao          String         @db.VarChar(20)  // "V0.1", "V1.0", "ASSINADO"
  ordem           Int            // sequencial para ordenação
  direccao        VersaoDireccao
  documentId      String?        @map("document_id") @db.Uuid
  hashSHA256      String?        @map("hash_sha256") @db.VarChar(64)
  seloTemporal    DateTime?      @map("selo_temporal") @db.Timestamptz
  comentario      String?        @db.Text
  criadoPor       String         @map("criado_por") @db.Uuid

  // Conteúdo editável da versão (Markdown + HTML render).
  // Permite drafting interno + IA + diff line-by-line. Quando há
  // PDF assinado externo, documentId aponta para o ficheiro e o
  // markdown fica como referência reconstrutível.
  corpoMarkdown   String?        @map("corpo_markdown") @db.Text
  corpoHtml       String?        @map("corpo_html") @db.Text
  geradoPorIA     Boolean        @default(false) @map("gerado_por_ia")

  // IA extraction
  extracao        Json?
  extracaoStatus  ExtracaoStatus? @map("extracao_status")
  extracaoConfianca Decimal?     @map("extracao_confianca") @db.Decimal(5, 4)
  extracaoEm      DateTime?      @map("extracao_em") @db.Timestamptz

  // Diff cache
  diffVsAnteriorId String?       @map("diff_vs_anterior_id") @db.Uuid
  diffResumo      Json?          @map("diff_resumo")

  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz

  contrato        Contrato       @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  assinaturas     ContratoAssinatura[]
  comentarios     ContratoComentario[]

  @@unique([contratoId, ordem])
  @@index([contratoId])
  @@map("contrato_versoes")
}

